# Copy to ndk_backend/.env and adjust. ndk_backend/.env is gitignored.

# Long random string used to sign gateway JWTs (REQUIRED for production).
JWT_SECRET=change-me-to-a-long-random-string

# Bearer token lifetime, in minutes (default 720 = 12h).
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Upstream NUST LMS base URL (include the /portal path segment).
LMS_BASE_URL=https://lms.nust.edu.pk/portal
# NUST LMS has TLS chain quirks; leave false unless your environment trusts its cert.
LMS_VERIFY_SSL=false

# CORS origins (JSON array). Narrow to your frontend origin in production.
# CORS_ORIGINS=["http://localhost:5173"]

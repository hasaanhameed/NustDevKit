# Keep the build context (and image) lean and secret-free.
# NOTE: do NOT exclude *.md — app/assistant/knowledge.md is loaded at runtime.
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# Secrets — never bake these into the image; pass env vars at runtime.
.env
.env.*

# Tooling caches / VCS / docker meta
.pytest_cache/
.mypy_cache/
.ruff_cache/
.git/
.gitignore
Dockerfile
.dockerignore

              <xs:documentation>Paginated enrolled-courses response.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="getEnrolledCoursesByTimeline400_Response0">
        <xs:sequence>
          <xs:element minOccurs="1" name="response400" type="schemas:MoodleError">
            <xs:annotation>
              <xs:documentation>Error returned by the LMS on a failed operation.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="getCourseContents200_Response0">
        <xs:sequence>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="response200" type="schemas:CourseSection">
            <xs:annotation>
              <xs:documentation>The course's sections, in display order.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="getCourseContents400_Response0">
        <xs:sequence>
          <xs:element minOccurs="1" name="response400" type="schemas:MoodleError">
            <xs:annotation>
              <xs:documentation>Error returned by the LMS on a failed operation.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="getCalendarEventsByTimesort200_Response0">
        <xs:sequence>
          <xs:element minOccurs="1" name="response200" type="schemas:CalendarEventsResponse">
            <xs:annotation>
              <xs:documentation>A list of calendar events with pagination boundary IDs.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="getCalendarEventsByTimesort400_Response0">

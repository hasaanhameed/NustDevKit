      </xs:complexType>
      <xs:complexType name="getCalendarEventsByCourse200_Response0">
        <xs:sequence>
          <xs:element minOccurs="1" name="response200" type="schemas:CalendarEventsResponse">
            <xs:annotation>
              <xs:documentation>A list of calendar events with pagination boundary IDs.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="getCalendarEventsByCourse400_Response0">

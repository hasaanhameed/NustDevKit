<?xml version="1.0" encoding="utf-8"?>
<application xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:schemas="http://127.0.0.1:8000/schemas" xmlns="http://wadl.dev.java.net/2009/02">
  <doc title="NUST LMS API" xml:lang="en">NUST Learning Management System API for developer integrations (Moodle AJAX wrapper).
Authenticate with your NUST LMS credentials via `POST /auth/login` to receive a bearer token, then call any operation with `Authorization: Bearer &lt;token&gt;`. The NustDevKit gateway logs into the LMS on your behalf and manages the underlying session (cookie + sesskey) server-side, so you never handle the ephemeral sesskey.
</doc>
  <grammars>
    <xs:schema xmlns:tns="http://127.0.0.1:8000/schemas" targetNamespace="http://127.0.0.1:8000/schemas" xmlns:xs="http://www.w3.org/2001/XMLSchema">
      <xs:element name="LoginRequest" type="schemas:LoginRequest" />
      <xs:element name="TokenResponse" type="schemas:TokenResponse" />
      <xs:element name="CourseTimelineClassification" type="schemas:CourseTimelineClassification" />
      <xs:element name="CourseTimelineSortField" type="schemas:CourseTimelineSortField" />
      <xs:element name="UserProfileField" type="schemas:UserProfileField" />
      <xs:element name="MoodleWarning" type="schemas:MoodleWarning" />
      <xs:element name="SiteNotification" type="schemas:SiteNotification" />
      <xs:element name="MoodleError" type="schemas:MoodleError" />
      <xs:element name="Course" type="schemas:Course" />
      <xs:element name="RecentCourseFields" type="schemas:RecentCourseFields" />
      <xs:element name="RecentCourse" type="schemas:RecentCourse" />
      <xs:element name="EnrolledCoursesResponse" type="schemas:EnrolledCoursesResponse" />
      <xs:element name="EventIcon" type="schemas:EventIcon" />
      <xs:element name="EventSubscription" type="schemas:EventSubscription" />
      <xs:element name="EventAction" type="schemas:EventAction" />
      <xs:element name="CalendarEvent" type="schemas:CalendarEvent" />
      <xs:element name="CalendarEventsResponse" type="schemas:CalendarEventsResponse" />
      <xs:element name="CustomField" type="schemas:CustomField" />
      <xs:element name="UserPreference" type="schemas:UserPreference" />
      <xs:element name="UserProfile" type="schemas:UserProfile" />
      <xs:element name="UserPreferencesResponse" type="schemas:UserPreferencesResponse" />
      <xs:element name="Notification" type="schemas:Notification" />
      <xs:element name="PopupNotificationsResponse" type="schemas:PopupNotificationsResponse" />
      <xs:element name="GetRecentCoursesRequest" type="schemas:GetRecentCoursesRequest" />
      <xs:element name="GetEnrolledCoursesByTimelineRequest" type="schemas:GetEnrolledCoursesByTimelineRequest" />
      <xs:element name="FetchNotificationsRequest" type="schemas:FetchNotificationsRequest" />
      <xs:element name="GetCalendarEventsByTimesortRequest" type="schemas:GetCalendarEventsByTimesortRequest" />
      <xs:element name="GetCalendarEventsByCourseRequest" type="schemas:GetCalendarEventsByCourseRequest" />
      <xs:element name="GetUsersByFieldRequest" type="schemas:GetUsersByFieldRequest" />
      <xs:element name="GetUserPreferencesRequest" type="schemas:GetUserPreferencesRequest" />
      <xs:element name="GetPopupNotificationsRequest" type="schemas:GetPopupNotificationsRequest" />
      <xs:element name="AuthLogin401Error1" type="schemas:AuthLogin401Error1" />
      <xs:element name="login_Request" type="schemas:login_Request" />
      <xs:element name="login200_Response0" type="schemas:login200_Response0" />
      <xs:element name="login401_Response0" type="schemas:login401_Response0" />
      <xs:element name="getCoreRecentCourses_Request" type="schemas:getCoreRecentCourses_Request" />
      <xs:element name="getCoreRecentCourses200_Response0" type="schemas:getCoreRecentCourses200_Response0" />
      <xs:element name="getCoreRecentCourses400_Response0" type="schemas:getCoreRecentCourses400_Response0" />
      <xs:element name="getEnrolledCoursesByTimeline_Request" type="schemas:getEnrolledCoursesByTimeline_Request" />
      <xs:element name="getEnrolledCoursesByTimeline200_Response0" type="schemas:getEnrolledCoursesByTimeline200_Response0" />
      <xs:element name="getEnrolledCoursesByTimeline400_Response0" type="schemas:getEnrolledCoursesByTimeline400_Response0" />
      <xs:element name="getCalendarEventsByTimesort_Request" type="schemas:getCalendarEventsByTimesort_Request" />
      <xs:element name="getCalendarEventsByTimesort200_Response0" type="schemas:getCalendarEventsByTimesort200_Response0" />
      <xs:element name="getCalendarEventsByTimesort400_Response0" type="schemas:getCalendarEventsByTimesort400_Response0" />
      <xs:element name="getCalendarEventsByCourse_Request" type="schemas:getCalendarEventsByCourse_Request" />
      <xs:element name="getCalendarEventsByCourse200_Response0" type="schemas:getCalendarEventsByCourse200_Response0" />
      <xs:element name="getCalendarEventsByCourse400_Response0" type="schemas:getCalendarEventsByCourse400_Response0" />
      <xs:element name="getUsersByField_Request" type="schemas:getUsersByField_Request" />
      <xs:element name="getUsersByField200_Response0" type="schemas:getUsersByField200_Response0" />
      <xs:element name="getUsersByField400_Response0" type="schemas:getUsersByField400_Response0" />
      <xs:element name="getUserPreferences_Request" type="schemas:getUserPreferences_Request" />
      <xs:element name="getUserPreferences200_Response0" type="schemas:getUserPreferences200_Response0" />
      <xs:element name="getUserPreferences400_Response0" type="schemas:getUserPreferences400_Response0" />
      <xs:element name="fetchNotifications_Request" type="schemas:fetchNotifications_Request" />
      <xs:element name="fetchNotifications200_Response0" type="schemas:fetchNotifications200_Response0" />
      <xs:element name="fetchNotifications400_Response0" type="schemas:fetchNotifications400_Response0" />
      <xs:element name="getPopupNotifications_Request" type="schemas:getPopupNotifications_Request" />
      <xs:element name="getPopupNotifications200_Response0" type="schemas:getPopupNotifications200_Response0" />
      <xs:element name="getPopupNotifications400_Response0" type="schemas:getPopupNotifications400_Response0" />
      <xs:complexType name="LoginRequest">
        <xs:annotation>
          <xs:documentation>NUST LMS credentials used to obtain a gateway bearer token.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="username" type="xs:string">
            <xs:annotation>
              <xs:documentation>NUST LMS username.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="password" type="xs:string">
            <xs:annotation>
              <xs:documentation>NUST LMS password.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="TokenResponse">
        <xs:annotation>
          <xs:documentation>Bearer token issued by the gateway after a successful login.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="access_token" type="xs:string">
            <xs:annotation>
              <xs:documentation>JWT to send as `Authorization: Bearer &lt;token&gt;` on subsequent requests.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" default="bearer" name="token_type" type="xs:string" />
        </xs:sequence>
      </xs:complexType>
      <xs:simpleType name="CourseTimelineClassification">
        <xs:annotation>
          <xs:documentation>Timeline classification filter for enrolled courses.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
          <xs:enumeration value="all" />
          <xs:enumeration value="inprogress" />
          <xs:enumeration value="past" />
          <xs:enumeration value="future" />
          <xs:enumeration value="favourite" />
          <xs:enumeration value="hidden" />
          <xs:enumeration value="allincludinghidden" />
        </xs:restriction>
      </xs:simpleType>
      <xs:simpleType name="CourseTimelineSortField">
        <xs:annotation>
          <xs:documentation>Field used to sort enrolled course results.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
          <xs:enumeration value="fullname" />
          <xs:enumeration value="shortname" />
          <xs:enumeration value="id" />
          <xs:enumeration value="idnumber" />
          <xs:enumeration value="timeaccess" />
        </xs:restriction>
      </xs:simpleType>
      <xs:simpleType name="UserProfileField">
        <xs:annotation>
          <xs:documentation>User profile field to match against when searching for users.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
          <xs:enumeration value="id" />
          <xs:enumeration value="idnumber" />
          <xs:enumeration value="username" />
          <xs:enumeration value="email" />
        </xs:restriction>
      </xs:simpleType>
      <xs:complexType name="MoodleWarning">
        <xs:annotation>
          <xs:documentation>A non-fatal warning returned alongside a successful response.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="0" name="item" type="xs:string">
            <xs:annotation>
              <xs:documentation>Item identifier related to the warning; empty string if not applicable.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="itemid" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Numeric item ID related to the warning; 0 if not applicable.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="warningcode" type="xs:string">
            <xs:annotation>
              <xs:documentation>Machine-readable warning code; empty string if no code.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="message" type="xs:string">
            <xs:annotation>
              <xs:documentation>Human-readable warning description.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="SiteNotification">
        <xs:annotation>
          <xs:documentation>A site-level notification (structure varies by type).</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="0" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unique identifier for the site notification.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="message" type="xs:string">
            <xs:annotation>
              <xs:documentation>Notification message content.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="type" type="xs:string">
            <xs:annotation>
              <xs:documentation>Notification type identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="MoodleError">
        <xs:annotation>
          <xs:documentation>Error returned by the LMS on a failed operation.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="0" name="errorcode" type="xs:string">
            <xs:annotation>
              <xs:documentation>Machine-readable error code identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="message" type="xs:string">
            <xs:annotation>
              <xs:documentation>Human-readable error description.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="link" type="xs:string">
            <xs:annotation>
              <xs:documentation>Redirect URL for the user; empty string if not applicable.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="moreinfourl" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to additional error documentation; empty string if not available.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="debuginfo" type="xs:string">
            <xs:annotation>
              <xs:documentation>Additional debug information; empty string when not in debug mode.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="Course">
        <xs:annotation>
          <xs:documentation>An enrolled course.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unique course identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="fullname" type="xs:string">
            <xs:annotation>
              <xs:documentation>Full display name of the course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="shortname" type="xs:string">
            <xs:annotation>
              <xs:documentation>Short course code or abbreviated name.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="idnumber" type="xs:string">
            <xs:annotation>
              <xs:documentation>Institution-assigned course ID number; empty string if not set.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="summary" type="xs:string">
            <xs:annotation>
              <xs:documentation>HTML summary of the course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="summaryformat" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Format of the summary field (1 = HTML).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="startdate" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Course start date as Unix timestamp.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="enddate" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Course end date as Unix timestamp. 0 means no end date.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="visible" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the course is visible to enrolled students.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="fullnamedisplay" type="xs:string">
            <xs:annotation>
              <xs:documentation>Display name of the course (may differ from fullname for context).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="viewurl" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to the course page on the LMS portal.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="progress">
            <xs:simpleType>
              <xs:annotation>
                <xs:documentation>Student's completion progress as a percentage.</xs:documentation>
              </xs:annotation>
              <xs:restriction base="xs:integer">
                <xs:maxInclusive value="100" />
                <xs:minInclusive value="0" />
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element minOccurs="1" name="hasprogress" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether completion tracking is enabled for this course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="isfavourite" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the user has marked this course as a favourite.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="hidden" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the user has hidden this course from their dashboard.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="showshortname" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the short name is displayed alongside the full name.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="coursecategory" type="xs:string">
            <xs:annotation>
              <xs:documentation>Name of the category this course belongs to.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="RecentCourseFields">
        <xs:annotation>
          <xs:documentation>Additional fields specific to recently accessed courses.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="timeaccess" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unix timestamp of the user's most recent access to this course.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="RecentCourse">
        <xs:annotation>
          <xs:documentation>A recently accessed course, extending Course with the last-access timestamp.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unique course identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="fullname" type="xs:string">
            <xs:annotation>
              <xs:documentation>Full display name of the course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="shortname" type="xs:string">
            <xs:annotation>
              <xs:documentation>Short course code or abbreviated name.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="idnumber" type="xs:string">
            <xs:annotation>
              <xs:documentation>Institution-assigned course ID number; empty string if not set.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="summary" type="xs:string">
            <xs:annotation>
              <xs:documentation>HTML summary of the course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="summaryformat" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Format of the summary field (1 = HTML).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="startdate" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Course start date as Unix timestamp.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="enddate" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Course end date as Unix timestamp. 0 means no end date.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="visible" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the course is visible to enrolled students.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="fullnamedisplay" type="xs:string">
            <xs:annotation>
              <xs:documentation>Display name of the course (may differ from fullname for context).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="viewurl" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to the course page on the LMS portal.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="progress">
            <xs:simpleType>
              <xs:annotation>
                <xs:documentation>Student's completion progress as a percentage.</xs:documentation>
              </xs:annotation>
              <xs:restriction base="xs:integer">
                <xs:maxInclusive value="100" />
                <xs:minInclusive value="0" />
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element minOccurs="1" name="hasprogress" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether completion tracking is enabled for this course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="isfavourite" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the user has marked this course as a favourite.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="hidden" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the user has hidden this course from their dashboard.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="showshortname" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the short name is displayed alongside the full name.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="coursecategory" type="xs:string">
            <xs:annotation>
              <xs:documentation>Name of the category this course belongs to.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="timeaccess" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unix timestamp of the user's most recent access to this course.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="EnrolledCoursesResponse">
        <xs:annotation>
          <xs:documentation>Paginated enrolled-courses response.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="courses" type="schemas:Course">
            <xs:annotation>
              <xs:documentation>List of enrolled courses for the current page.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="nextoffset" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Offset to pass on the next page request; -1 when no further pages exist.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="EventIcon">
        <xs:annotation>
          <xs:documentation>Icon metadata for a calendar event.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="key" type="xs:string">
            <xs:annotation>
              <xs:documentation>Icon key name used to locate the icon asset.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="component" type="xs:string">
            <xs:annotation>
              <xs:documentation>Moodle component that owns the icon (e.g., 'assign').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="alttext" type="xs:string">
            <xs:annotation>
              <xs:documentation>Accessible alt text for the icon image.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="EventSubscription">
        <xs:annotation>
          <xs:documentation>Subscription display settings for a calendar event.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="displayeventsource" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether to display the event source label on the calendar.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="EventAction">
        <xs:annotation>
          <xs:documentation>Primary action button metadata for a calendar event.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Display label for the primary action button.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="url" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL the user should navigate to in order to perform the action.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="itemcount" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Number of items associated with this action.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="actionable" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the action can currently be taken by the user.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="showitemcount" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether to display the item count alongside the action label.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="CalendarEvent">
        <xs:annotation>
          <xs:documentation>A calendar action event. On NUST LMS these represent deadlines — the due date for an assignment, lab, quiz, or other submission tied to a course activity.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unique calendar event identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Display name of the calendar event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="description" type="xs:string">
            <xs:annotation>
              <xs:documentation>HTML description body of the event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="descriptionformat" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Text format of the description (1 = HTML).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="location" type="xs:string">
            <xs:annotation>
              <xs:documentation>Physical or virtual location of the event; empty string if not specified.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="categoryid" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Course category ID; null if not a category event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="groupid" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Group ID if the event is group-specific; null otherwise.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="userid" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>User ID if the event is user-specific; null otherwise.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="repeatid" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the repeat group for recurring events; null if not recurring.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="eventcount" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Total number of events in the repeat group; null if not applicable.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="component" type="xs:string">
            <xs:annotation>
              <xs:documentation>Moodle component that created the event (e.g., 'mod_assign').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="modulename" type="xs:string">
            <xs:annotation>
              <xs:documentation>Short name of the Moodle activity module (e.g., 'assign').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="instance" type="xs:integer">
            <xs:annotation>
              <xs:documentation>The course module instance ID.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="eventtype" type="xs:string">
            <xs:annotation>
              <xs:documentation>Type of the event (e.g., 'due', 'open', 'close').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="timestart" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Event start time as Unix timestamp.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="timeduration" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Duration in seconds; 0 for point-in-time events.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="timesort" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Sort timestamp used for ordering events.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="visible" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Visibility flag for a calendar event. 1 means the event is visible; 0 means it is hidden.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="timemodified" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Last modification time as Unix timestamp.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="icon" type="schemas:EventIcon">
            <xs:annotation>
              <xs:documentation>Icon metadata for a calendar event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="course" type="schemas:Course">
            <xs:annotation>
              <xs:documentation>An enrolled course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="subscription" type="schemas:EventSubscription">
            <xs:annotation>
              <xs:documentation>Subscription display settings for a calendar event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="canedit" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the current user can edit this event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="candelete" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the current user can delete this event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="deleteurl" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to delete this calendar event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="editurl" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to edit the underlying course module associated with this event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="viewurl" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to view this event on the calendar.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="formattedtime" type="xs:string">
            <xs:annotation>
              <xs:documentation>HTML-formatted human-readable event time string.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="isactionevent" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether this is an action event requiring user interaction.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="iscourseevent" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether this event is associated with a specific course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="iscategoryevent" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether this event is associated with a course category.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="groupname" nillable="true" type="xs:string">
            <xs:annotation>
              <xs:documentation>Name of the group for group-specific events; null otherwise.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="normalisedeventtype" type="xs:string">
            <xs:annotation>
              <xs:documentation>Normalised event type identifier used for display grouping.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="normalisedeventtypetext" type="xs:string">
            <xs:annotation>
              <xs:documentation>Human-readable label for the normalised event type.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="action" type="schemas:EventAction">
            <xs:annotation>
              <xs:documentation>Primary action button metadata for a calendar event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="url" type="xs:string">
            <xs:annotation>
              <xs:documentation>Direct URL to the course activity associated with this event.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="CalendarEventsResponse">
        <xs:annotation>
          <xs:documentation>A list of calendar events with pagination boundary IDs.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="events" type="schemas:CalendarEvent">
            <xs:annotation>
              <xs:documentation>List of calendar action events for the current result set.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="firstid" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Event ID of the first item in the result set.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="lastid" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Event ID of the last item in the result set.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="CustomField">
        <xs:annotation>
          <xs:documentation>A custom profile field value attached to a user.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="type" type="xs:string">
            <xs:annotation>
              <xs:documentation>Data type of the custom field (e.g., 'text', 'select').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="value" type="xs:string">
            <xs:annotation>
              <xs:documentation>Value stored in the custom field.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Display label of the custom field.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="shortname" type="xs:string">
            <xs:annotation>
              <xs:documentation>Machine-readable shortname identifier for the custom field.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="UserPreference">
        <xs:annotation>
          <xs:documentation>A single user preference setting.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Unique key identifying the preference.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="value" type="xs:string">
            <xs:annotation>
              <xs:documentation>Preference value as a string. Note that the internal _lastloaded preference is returned as an integer by the LMS.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="UserProfile">
        <xs:annotation>
          <xs:documentation>Complete user profile.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unique numeric user identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="username" type="xs:string">
            <xs:annotation>
              <xs:documentation>Login username for the user.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="fullname" type="xs:string">
            <xs:annotation>
              <xs:documentation>Full display name of the user.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="email" type="xs:string">
            <xs:annotation>
              <xs:documentation>Email address of the user.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="department" type="xs:string">
            <xs:annotation>
              <xs:documentation>Department the user belongs to within the institution.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="institution" type="xs:string">
            <xs:annotation>
              <xs:documentation>Name of the institution the user is affiliated with.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="idnumber" type="xs:string">
            <xs:annotation>
              <xs:documentation>Institution-assigned student or staff ID number.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="auth" type="xs:string">
            <xs:annotation>
              <xs:documentation>Authentication method used by the user (e.g., 'ldap', 'manual').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="confirmed" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the user's account has been confirmed.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="lang" type="xs:string">
            <xs:annotation>
              <xs:documentation>Preferred interface language code (e.g., 'en').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="theme" type="xs:string">
            <xs:annotation>
              <xs:documentation>Preferred LMS theme; empty string means use the site default.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="timezone" type="xs:string">
            <xs:annotation>
              <xs:documentation>Timezone identifier. "99" means use the server default.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="mailformat" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Email format preference (1 = HTML).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="profileimageurlsmall" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to the user's small profile image (thumbnail).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="profileimageurl" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to the user's full-size profile image.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" maxOccurs="unbounded" name="customfields" type="schemas:CustomField">
            <xs:annotation>
              <xs:documentation>List of custom profile field values for the user.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" maxOccurs="unbounded" name="preferences" type="schemas:UserPreference">
            <xs:annotation>
              <xs:documentation>List of stored preference key/value pairs for the user.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="UserPreferencesResponse">
        <xs:annotation>
          <xs:documentation>Response envelope for the user-preferences endpoint.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="preferences" type="schemas:UserPreference">
            <xs:annotation>
              <xs:documentation>List of user preference key/value pairs.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="warnings" type="schemas:MoodleWarning">
            <xs:annotation>
              <xs:documentation>Array of warning objects. Empty when no warnings are present.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="Notification">
        <xs:annotation>
          <xs:documentation>A popup notification message delivered to a user.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unique notification identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="useridfrom" type="xs:integer">
            <xs:annotation>
              <xs:documentation>User ID of the sender.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="useridto" type="xs:integer">
            <xs:annotation>
              <xs:documentation>User ID of the recipient.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="subject" type="xs:string">
            <xs:annotation>
              <xs:documentation>Subject line of the notification.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="shortenedsubject" type="xs:string">
            <xs:annotation>
              <xs:documentation>Shortened version of the notification subject for compact display.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="text" type="xs:string">
            <xs:annotation>
              <xs:documentation>Short HTML excerpt of the notification.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="fullmessage" type="xs:string">
            <xs:annotation>
              <xs:documentation>Full plain-text body of the notification.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="fullmessageformat" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Format identifier for fullmessagehtml (2 = Markdown source).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="fullmessagehtml" type="xs:string">
            <xs:annotation>
              <xs:documentation>Full HTML body of the notification email.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="smallmessage" type="xs:string">
            <xs:annotation>
              <xs:documentation>Short plain-text preview of the notification.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="contexturl" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to the relevant context for this notification (e.g., a forum post).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="contexturlname" type="xs:string">
            <xs:annotation>
              <xs:documentation>Human-readable label for the context URL link.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="timecreated" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unix timestamp when the notification was created.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="timecreatedpretty" type="xs:string">
            <xs:annotation>
              <xs:documentation>Human-readable relative time string (e.g., '19 days ago').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="timeread" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unix timestamp when the notification was read; null if unread.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="read" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the notification has been read by the recipient.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="deleted" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the notification has been deleted by the recipient.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="iconurl" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to the icon image representing the notification source.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="component" type="xs:string">
            <xs:annotation>
              <xs:documentation>Moodle component that generated the notification (e.g., 'mod_forum').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="eventtype" type="xs:string">
            <xs:annotation>
              <xs:documentation>Event type within the component that triggered the notification (e.g., 'posts').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="customdata" type="xs:string">
            <xs:annotation>
              <xs:documentation>JSON-encoded string with additional notification metadata (cmid, instance, discussionid, postid, etc.).</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="PopupNotificationsResponse">
        <xs:annotation>
          <xs:documentation>Response envelope for the popup-notifications endpoint.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="notifications" type="schemas:Notification">
            <xs:annotation>
              <xs:documentation>List of popup notifications for the user.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="unreadcount" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Total number of unread notifications for the user.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="GetRecentCoursesRequest">
        <xs:annotation>
          <xs:documentation>Request parameters for retrieving recently accessed courses.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" default="10" name="limit" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Maximum number of courses to return.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="GetEnrolledCoursesByTimelineRequest">
        <xs:annotation>
          <xs:documentation>Request parameters for retrieving enrolled courses filtered by timeline classification.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" default="0" name="offset" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Zero-based pagination offset.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" default="50" name="limit" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Maximum number of courses to return.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="classification" type="schemas:CourseTimelineClassification">
            <xs:annotation>
              <xs:documentation>Timeline classification filter for enrolled courses.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="sort" type="schemas:CourseTimelineSortField">
            <xs:annotation>
              <xs:documentation>Field used to sort enrolled course results.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="FetchNotificationsRequest">
        <xs:annotation>
          <xs:documentation>Request parameters for fetching site-level notifications.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="contextid" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Moodle context ID for which to fetch notifications. The user context ID can be found in the user profile image URL path segment.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="GetCalendarEventsByTimesortRequest">
        <xs:annotation>
          <xs:documentation>Request parameters for retrieving calendar action events sorted by time.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="limitnum" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Maximum number of events to return.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="timesortfrom" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Only return events with timesort &gt;= this Unix timestamp. Pass 0 for no lower bound.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="timesortto" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Only return events with timesort &lt;= this Unix timestamp. Optional.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="aftereventid" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Return events whose ID is greater than this value (cursor pagination). Optional.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="GetCalendarEventsByCourseRequest">
        <xs:annotation>
          <xs:documentation>Request parameters for retrieving calendar action events for a specific course.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="courseid" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the course to fetch events for.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="timesortfrom" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Only return events with timesort &gt;= this Unix timestamp. Optional.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="timesortto" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Only return events with timesort &lt;= this Unix timestamp. Optional.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="aftereventid" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Cursor-based pagination — return events after this event ID. Optional.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="limitnum" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Maximum number of events to return. Optional.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="GetUsersByFieldRequest">
        <xs:annotation>
          <xs:documentation>Request parameters for retrieving user profiles by a profile field value.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="field" type="schemas:UserProfileField">
            <xs:annotation>
              <xs:documentation>User profile field to match against when searching for users.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="values" type="xs:string">
            <xs:annotation>
              <xs:documentation>List of field values to look up. All values must be provided as strings even when the field is numeric (e.g., "123456" for an integer ID).</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="GetUserPreferencesRequest">
        <xs:annotation>
          <xs:documentation>Request parameters for retrieving user preferences.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="userid" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the user whose preferences to retrieve.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Specific preference name to retrieve. Omit to retrieve all preferences.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="GetPopupNotificationsRequest">
        <xs:annotation>
          <xs:documentation>Request parameters for retrieving popup notifications for a user.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="useridto" type="xs:string">
            <xs:annotation>
              <xs:documentation>ID of the recipient user, passed as a string.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="limit" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Maximum number of notifications to return.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" default="0" name="offset" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Pagination offset.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="AuthLogin401Error1">
        <xs:sequence>
          <xs:element minOccurs="0" name="detail" type="xs:string" />
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="login_Request">
        <xs:sequence>

- CustomField: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "CustomField",
      "title": "CustomField",
      "description": "A custom profile field value attached to a user.",
      "type": "object",
      "properties": {
        "type": {
          "description": "Data type of the custom field (e.g., 'text', 'select').",
          "example": "text",
          "type": "string"
        },
        "value": {
          "description": "Value stored in the custom field.",
          "example": "SEECS",
          "type": "string"
        },
        "name": {
          "description": "Display label of the custom field.",
          "example": "Institute",
          "type": "string"
        },
        "shortname": {
          "description": "Machine-readable shortname identifier for the custom field.",
          "example": "institution",
          "type": "string"
        }
      },
      "required": [
        "type",
        "value",
        "name",
        "shortname"
      ]
    }
- UserPreference: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "UserPreference",
      "title": "UserPreference",
      "description": "A single user preference setting.",
      "type": "object",
      "properties": {
        "name": {
          "description": "Unique key identifying the preference.",
          "example": "block_myoverview_user_sort_preference",
          "type": "string"
        },
        "value": {
          "description": "Preference value as a string. Note that the internal _lastloaded preference is returned as an integer by the LMS.",
          "example": "title",
          "type": "string"
        }
      },
      "required": [
        "name",
        "value"
      ]
    }
- UserProfile: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "UserProfile",
      "title": "UserProfile",
      "description": "Complete user profile.",
      "type": "object",
      "properties": {
        "id": {
          "description": "Unique numeric user identifier.",
          "example": 162154,
          "type": "integer",
          "format": "int32"
        },
        "username": {
          "description": "Login username for the user.",
          "example": "hhameed.bscs23seecs",
          "type": "string"
        },
        "fullname": {
          "description": "Full display name of the user.",
          "example": "Hasaan Hameed",
          "type": "string"
        },
        "email": {
          "description": "Email address of the user.",
          "example": "hhameed.bscs23seecs@seecs.edu.pk",
          "type": "string"
        },
        "department": {
          "description": "Department the user belongs to within the institution.",
          "example": "FoC",
          "type": "string"
        },
        "institution": {
          "description": "Name of the institution the user is affiliated with.",
          "example": "SEECS",
          "type": "string"
        },
        "idnumber": {
          "description": "Institution-assigned student or staff ID number.",
          "example": "00000454987",
          "type": "string"
        },
        "auth": {
          "description": "Authentication method used by the user (e.g., 'ldap', 'manual').",
          "example": "ldap",
          "type": "string"
        },
        "confirmed": {
          "description": "Whether the user's account has been confirmed.",
          "example": true,
          "type": "boolean"
        },
        "lang": {
          "description": "Preferred interface language code (e.g., 'en').",
          "example": "en",
          "type": "string"
        },
        "theme": {
          "description": "Preferred LMS theme; empty string means use the site default.",
          "type": "string"
        },
        "timezone": {
          "description": "Timezone identifier. \"99\" means use the server default.",
          "example": "99",
          "type": "string"
        },
        "mailformat": {
          "description": "Email format preference (1 = HTML).",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "profileimageurlsmall": {
          "description": "URL to the user's small profile image (thumbnail).",
          "example": "https://lms.nust.edu.pk/portal/pluginfile.php/1583361/user/icon/moove/f2?rev=14452894",
          "type": "string"
        },
        "profileimageurl": {
          "description": "URL to the user's full-size profile image.",
          "example": "https://lms.nust.edu.pk/portal/pluginfile.php/1583361/user/icon/moove/f1?rev=14452894",
          "type": "string"
        },
        "customfields": {
          "description": "List of custom profile field values for the user.",
          "type": "array",
          "items": {
            "id": "CustomField",
            "title": "CustomField",
            "description": "A custom profile field value attached to a user.",
            "type": "object",
            "properties": {
              "type": {
                "description": "Data type of the custom field (e.g., 'text', 'select').",
                "example": "text",
                "type": "string"
              },
              "value": {
                "description": "Value stored in the custom field.",
                "example": "SEECS",
                "type": "string"
              },
              "name": {
                "description": "Display label of the custom field.",
                "example": "Institute",
                "type": "string"
              },
              "shortname": {
                "description": "Machine-readable shortname identifier for the custom field.",
                "example": "institution",
                "type": "string"
              }
            },
            "required": [
              "type",
              "value",
              "name",
              "shortname"
            ]
          }
        },
        "preferences": {
          "description": "List of stored preference key/value pairs for the user.",
          "type": "array",
          "items": {
            "id": "UserPreference",
            "title": "UserPreference",
            "description": "A single user preference setting.",
            "type": "object",
            "properties": {
              "name": {
                "description": "Unique key identifying the preference.",
                "example": "block_myoverview_user_sort_preference",
                "type": "string"
              },
              "value": {
                "description": "Preference value as a string. Note that the internal _lastloaded preference is returned as an integer by the LMS.",
                "example": "title",
                "type": "string"
              }
            },
            "required": [
              "name",
              "value"
            ]
          }
        }
      },
      "required": [
        "id",
        "username",
        "fullname",
        "email",
        "department",
        "institution",
        "idnumber",
        "auth",
        "confirmed",
        "lang",
        "theme",
        "timezone",
        "mailformat",
        "profileimageurlsmall",
        "profileimageurl"
      ]
    }
- UserPreferencesResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "UserPreferencesResponse",
      "title": "UserPreferencesResponse",
      "description": "Response envelope for the user-preferences endpoint.",
      "type": "object",
      "properties": {
        "preferences": {
          "description": "List of user preference key/value pairs.",
          "type": "array",
          "items": {
            "id": "UserPreference",
            "title": "UserPreference",
            "description": "A single user preference setting.",
            "type": "object",
            "properties": {
              "name": {
                "description": "Unique key identifying the preference.",
                "example": "block_myoverview_user_sort_preference",
                "type": "string"
              },
              "value": {
                "description": "Preference value as a string. Note that the internal _lastloaded preference is returned as an integer by the LMS.",
                "example": "title",
                "type": "string"
              }
            },
            "required": [
              "name",
              "value"
            ]
          }
        },
        "warnings": {
          "description": "Array of warning objects. Empty when no warnings are present.",
          "type": "array",
          "items": {
            "id": "MoodleWarning",
            "title": "MoodleWarning",
            "description": "A non-fatal warning returned alongside a successful response.",
            "type": "object",
            "properties": {
              "item": {
                "description": "Item identifier related to the warning; empty string if not applicable.",
                "type": "string"
              },
              "itemid": {
                "description": "Numeric item ID related to the warning; 0 if not applicable.",
                "example": 0,
                "type": "integer",
                "format": "int32"
              },
              "warningcode": {
                "description": "Machine-readable warning code; empty string if no code.",
                "type": "string"
              },
              "message": {
                "description": "Human-readable warning description.",
                "type": "string"
              }
            }
          }
        }
      },
      "required": [
        "preferences",
        "warnings"
      ]
    }
- Notification: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "Notification",
      "title": "Notification",
      "description": "A popup notification message delivered to a user.",
      "type": "object",
      "properties": {
        "id": {
          "description": "Unique notification identifier.",
          "example": 4857819,
          "type": "integer",
          "format": "int32"
        },
        "useridfrom": {
          "description": "User ID of the sender.",
          "example": 198956,
          "type": "integer",
          "format": "int32"
        },
        "useridto": {
          "description": "User ID of the recipient.",
          "example": 162154,
          "type": "integer",
          "format": "int32"
        },
        "subject": {
          "description": "Subject line of the notification.",
          "example": "CS-419-Deep Learning: Lab Sessional Finalization",
          "type": "string"
        },
        "shortenedsubject": {
          "description": "Shortened version of the notification subject for compact display.",
          "example": "CS-419-Deep Learning: Lab Sessional Finalization",
          "type": "string"
        },
        "text": {
          "description": "Short HTML excerpt of the notification.",
          "example": "<p>Areeba Rameen posted in CS-419-Deep Learning...</p>",
          "type": "string"
        },
        "fullmessage": {
          "description": "Full plain-text body of the notification.",
          "type": "string"
        },
        "fullmessageformat": {
          "description": "Format identifier for fullmessagehtml (2 = Markdown source).",
          "example": 2,
          "type": "integer",
          "format": "int32"
        },
        "fullmessagehtml": {
          "description": "Full HTML body of the notification email.",
          "type": "string"
        },
        "smallmessage": {
          "description": "Short plain-text preview of the notification.",
          "example": "Areeba Rameen posted in CS-419-Deep Learning...",
          "type": "string"
        },
        "contexturl": {
          "description": "URL to the relevant context for this notification (e.g., a forum post).",
          "example": "https://lms.nust.edu.pk/portal/mod/forum/discuss.php?d=41767#p52342",
          "type": "string"
        },
        "contexturlname": {
          "description": "Human-readable label for the context URL link.",
          "example": "Lab Sessional Finalization - (DL - Section D & E)",
          "type": "string"
        },
        "timecreated": {
          "description": "Unix timestamp when the notification was created.",
          "example": 1780045085,
          "type": "integer",
          "format": "int32"
        },
        "timecreatedpretty": {
          "description": "Human-readable relative time string (e.g., '19 days ago').",
          "example": "19 days ago",
          "type": "string"
        },
        "read": {
          "description": "Whether the notification has been read by the recipient.",
          "example": false,
          "type": "boolean"
        },
        "deleted": {
          "description": "Whether the notification has been deleted by the recipient.",
          "example": false,
          "type": "boolean"
        },
        "iconurl": {
          "description": "URL to the icon image representing the notification source.",
          "example": "https://lms.nust.edu.pk/portal/theme/image.php/moove/mod_forum/1778048051/icon",
          "type": "string"
        },
        "component": {
          "description": "Moodle component that generated the notification (e.g., 'mod_forum').",
          "example": "mod_forum",
          "type": "string"
        },
        "eventtype": {
          "description": "Event type within the component that triggered the notification (e.g., 'posts').",
          "example": "posts",
          "type": "string"
        },
        "customdata": {
          "description": "JSON-encoded string with additional notification metadata (cmid, instance, discussionid, postid, etc.).",
          "example": {
            "cmid": "1272420",
            "instance": "62569",
            "discussionid": "41767"
          },
          "type": "string"
        },
        "timeread": {
          "description": "Unix timestamp when the notification was read; null if unread.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        }
      },
      "required": [
        "id",
        "useridfrom",
        "useridto",
        "subject",
        "shortenedsubject",
        "text",
        "fullmessage",
        "fullmessageformat",
        "fullmessagehtml",
        "smallmessage",
        "contexturl",
        "contexturlname",
        "timecreated",
        "timecreatedpretty",
        "read",
        "deleted",
        "iconurl",
        "component",
        "eventtype",
        "customdata"
      ]
    }

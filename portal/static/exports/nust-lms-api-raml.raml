#%RAML 0.8
title: NUST LMS API
version: 1.0.0
documentation:
- title: NUST LMS API
  content: |
    NUST Learning Management System API for developer integrations (Moodle AJAX wrapper).

    Authenticate with your NUST LMS credentials via `POST /auth/login` to receive a bearer token, then call any operation with `Authorization: Bearer <token>`. The NustDevKit gateway logs into the LMS on your behalf and manages the underlying session (cookie + sesskey) server-side, so you never handle the ephemeral sesskey.
baseUri: http://127.0.0.1:8000
securedBy:
- BearerAuth
protocols:
- HTTP
- HTTPS
baseUriParameters: {}
schemas:
- LoginRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "LoginRequest",
      "title": "LoginRequest",
      "description": "NUST LMS credentials used to obtain a gateway bearer token.",
      "type": "object",
      "properties": {
        "email": {
          "description": "NUST LMS username or email.",
          "example": "john.doe@student.nust.edu.pk",
          "type": "string"
        },
        "password": {
          "description": "NUST LMS password.",
          "type": "string",
          "format": "password"
        }
      },
      "required": [
        "email",
        "password"
      ]
    }
- TokenResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "TokenResponse",
      "title": "TokenResponse",
      "description": "Bearer token issued by the gateway after a successful login.",
      "type": "object",
      "properties": {
        "access_token": {
          "description": "JWT to send as `Authorization: Bearer <token>` on subsequent requests.",
          "type": "string"
        },
        "token_type": {
          "example": "bearer",
          "type": "string"
        }
      },
      "required": [
        "access_token",
        "token_type"
      ]
    }
- CourseTimelineClassification: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "title": "CourseTimelineClassification",
      "description": "Timeline classification filter for enrolled courses.",
      "type": "string",
      "additionalProperties": false,
      "enum": [
        "all",
        "inprogress",
        "past",
        "future",
        "favourite",
        "hidden",
        "allincludinghidden"
      ]
    }
- CourseTimelineSortField: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "title": "CourseTimelineSortField",
      "description": "Field used to sort enrolled course results.",
      "type": "string",
      "additionalProperties": false,
      "enum": [
        "fullname",
        "shortname",
        "id",
        "idnumber",
        "timeaccess"
      ]
    }
- UserProfileField: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "title": "UserProfileField",
      "description": "User profile field to match against when searching for users.",
      "type": "string",
      "additionalProperties": false,
      "enum": [
        "id",
        "idnumber",
        "username",
        "email"
      ]
    }
- MoodleWarning: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "MoodleWarning",
      "title": "MoodleWarning",
      "description": "A non-fatal warning returned alongside a successful response.",
      "type": "object",
      "properties": {
        "item": {
          "description": "Item identifier related to the warning; empty string if not applicable.",
          "type": "string"
        },
        "itemid": {
          "description": "Numeric item ID related to the warning; 0 if not applicable.",
          "example": 0,
          "type": "integer",
          "format": "int32"
        },
        "warningcode": {
          "description": "Machine-readable warning code; empty string if no code.",
          "type": "string"
        },
        "message": {
          "description": "Human-readable warning description.",
          "type": "string"
        }
      }
    }
- SiteNotification: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "SiteNotification",
      "title": "SiteNotification",
      "description": "A site-level notification (structure varies by type).",
      "type": "object",
      "properties": {
        "id": {
          "description": "Unique identifier for the site notification.",
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "description": "Notification message content.",
          "type": "string"
        },
        "type": {
          "description": "Notification type identifier.",
          "type": "string"
        }
      }
    }
- MoodleError: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "MoodleError",
      "title": "MoodleError",
      "description": "Error returned by the LMS on a failed operation.",
      "type": "object",
      "properties": {
        "errorcode": {
          "description": "Machine-readable error code identifier.",
          "example": "invalidrecord",
          "type": "string"
        },
        "message": {
          "description": "Human-readable error description.",
          "example": "Can't find data record in database table.",
          "type": "string"
        },
        "link": {
          "description": "Redirect URL for the user; empty string if not applicable.",
          "type": "string"
        },
        "moreinfourl": {
          "description": "URL to additional error documentation; empty string if not available.",
          "type": "string"
        },
        "debuginfo": {
          "description": "Additional debug information; empty string when not in debug mode.",
          "type": "string"
        }
      }
    }
- Course: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "Course",
      "title": "Course",
      "description": "An enrolled course.",
      "type": "object",
      "properties": {
        "id": {
          "description": "Unique course identifier.",
          "example": 49900,
          "type": "integer",
          "format": "int32"
        },
        "fullname": {
          "description": "Full display name of the course.",
          "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
          "type": "string"
        },
        "shortname": {
          "description": "Short course code or abbreviated name.",
          "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
          "type": "string"
        },
        "idnumber": {
          "description": "Institution-assigned course ID number; empty string if not set.",
          "type": "string"
        },
        "summary": {
          "description": "HTML summary of the course.",
          "type": "string"
        },
        "summaryformat": {
          "description": "Format of the summary field (1 = HTML).",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "startdate": {
          "description": "Course start date as Unix timestamp.",
          "example": 1706468400,
          "type": "integer",
          "format": "int32"
        },
        "enddate": {
          "description": "Course end date as Unix timestamp. 0 means no end date.",
          "example": 1717362000,
          "type": "integer",
          "format": "int32"
        },
        "visible": {
          "description": "Whether the course is visible to enrolled students.",
          "example": true,
          "type": "boolean"
        },
        "fullnamedisplay": {
          "description": "Display name of the course (may differ from fullname for context).",
          "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
          "type": "string"
        },
        "viewurl": {
          "description": "URL to the course page on the LMS portal.",
          "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
          "type": "string"
        },
        "progress": {
          "description": "Student's completion progress as a percentage.",
          "example": 21,
          "type": "integer",
          "minimum": 0.0,
          "maximum": 100.0,
          "format": "int32"
        },
        "hasprogress": {
          "description": "Whether completion tracking is enabled for this course.",
          "example": true,
          "type": "boolean"
        },
        "isfavourite": {
          "description": "Whether the user has marked this course as a favourite.",
          "example": false,
          "type": "boolean"
        },
        "hidden": {
          "description": "Whether the user has hidden this course from their dashboard.",
          "example": false,
          "type": "boolean"
        },
        "showshortname": {
          "description": "Whether the short name is displayed alongside the full name.",
          "example": false,
          "type": "boolean"
        },
        "coursecategory": {
          "description": "Name of the category this course belongs to.",
          "example": "2nd Semester (SP-2024)",
          "type": "string"
        }
      },
      "required": [
        "id",
        "fullname",
        "shortname",
        "idnumber",
        "summary",
        "summaryformat",
        "startdate",
        "enddate",
        "visible",
        "fullnamedisplay",
        "viewurl",
        "progress",
        "hasprogress",
        "isfavourite",
        "hidden",
        "showshortname",
        "coursecategory"
      ]
    }
- RecentCourseFields: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "RecentCourseFields",
      "title": "RecentCourseFields",
      "description": "Additional fields specific to recently accessed courses.",
      "type": "object",
      "properties": {
        "timeaccess": {
          "description": "Unix timestamp of the user's most recent access to this course.",
          "example": 1781632422,
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "timeaccess"
      ]
    }
- RecentCourse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "RecentCourse",
      "title": "RecentCourse",
      "description": "A recently accessed course, extending Course with the last-access timestamp.",
      "type": "object",
      "properties": {
        "id": {
          "description": "Unique course identifier.",
          "example": 49900,
          "type": "integer",
          "format": "int32"
        },
        "fullname": {
          "description": "Full display name of the course.",
          "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
          "type": "string"
        },
        "shortname": {
          "description": "Short course code or abbreviated name.",
          "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
          "type": "string"
        },
        "idnumber": {
          "description": "Institution-assigned course ID number; empty string if not set.",
          "type": "string"
        },
        "summary": {
          "description": "HTML summary of the course.",
          "type": "string"
        },
        "summaryformat": {
          "description": "Format of the summary field (1 = HTML).",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "startdate": {
          "description": "Course start date as Unix timestamp.",
          "example": 1706468400,
          "type": "integer",
          "format": "int32"
        },
        "enddate": {
          "description": "Course end date as Unix timestamp. 0 means no end date.",
          "example": 1717362000,
          "type": "integer",
          "format": "int32"
        },
        "visible": {
          "description": "Whether the course is visible to enrolled students.",
          "example": true,
          "type": "boolean"
        },
        "fullnamedisplay": {
          "description": "Display name of the course (may differ from fullname for context).",
          "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
          "type": "string"
        },
        "viewurl": {
          "description": "URL to the course page on the LMS portal.",
          "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
          "type": "string"
        },
        "progress": {
          "description": "Student's completion progress as a percentage.",
          "example": 21,
          "type": "integer",
          "minimum": 0.0,
          "maximum": 100.0,
          "format": "int32"
        },
        "hasprogress": {
          "description": "Whether completion tracking is enabled for this course.",
          "example": true,
          "type": "boolean"
        },
        "isfavourite": {
          "description": "Whether the user has marked this course as a favourite.",
          "example": false,
          "type": "boolean"
        },
        "hidden": {
          "description": "Whether the user has hidden this course from their dashboard.",
          "example": false,
          "type": "boolean"
        },
        "showshortname": {
          "description": "Whether the short name is displayed alongside the full name.",
          "example": false,
          "type": "boolean"
        },
        "coursecategory": {
          "description": "Name of the category this course belongs to.",
          "example": "2nd Semester (SP-2024)",
          "type": "string"
        },
        "timeaccess": {
          "description": "Unix timestamp of the user's most recent access to this course.",
          "example": 1781632422,
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "id",
        "fullname",
        "shortname",
        "idnumber",
        "summary",
        "summaryformat",
        "startdate",
        "enddate",
        "visible",
        "fullnamedisplay",
        "viewurl",
        "progress",
        "hasprogress",
        "isfavourite",
        "hidden",
        "showshortname",
        "coursecategory",
        "timeaccess"
      ]
    }
- EnrolledCoursesResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "EnrolledCoursesResponse",
      "title": "EnrolledCoursesResponse",
      "description": "Paginated enrolled-courses response.",
      "type": "object",
      "properties": {
        "courses": {
          "description": "List of enrolled courses for the current page.",
          "type": "array",
          "items": {
            "id": "Course",
            "title": "Course",
            "description": "An enrolled course.",
            "type": "object",
            "properties": {
              "id": {
                "description": "Unique course identifier.",
                "example": 49900,
                "type": "integer",
                "format": "int32"
              },
              "fullname": {
                "description": "Full display name of the course.",
                "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                "type": "string"
              },
              "shortname": {
                "description": "Short course code or abbreviated name.",
                "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
                "type": "string"
              },
              "idnumber": {
                "description": "Institution-assigned course ID number; empty string if not set.",
                "type": "string"
              },
              "summary": {
                "description": "HTML summary of the course.",
                "type": "string"
              },
              "summaryformat": {
                "description": "Format of the summary field (1 = HTML).",
                "example": 1,
                "type": "integer",
                "format": "int32"
              },
              "startdate": {
                "description": "Course start date as Unix timestamp.",
                "example": 1706468400,
                "type": "integer",
                "format": "int32"
              },
              "enddate": {
                "description": "Course end date as Unix timestamp. 0 means no end date.",
                "example": 1717362000,
                "type": "integer",
                "format": "int32"
              },
              "visible": {
                "description": "Whether the course is visible to enrolled students.",
                "example": true,
                "type": "boolean"
              },
              "fullnamedisplay": {
                "description": "Display name of the course (may differ from fullname for context).",
                "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                "type": "string"
              },
              "viewurl": {
                "description": "URL to the course page on the LMS portal.",
                "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
                "type": "string"
              },
              "progress": {
                "description": "Student's completion progress as a percentage.",
                "example": 21,
                "type": "integer",
                "minimum": 0.0,
                "maximum": 100.0,
                "format": "int32"
              },
              "hasprogress": {
                "description": "Whether completion tracking is enabled for this course.",
                "example": true,
                "type": "boolean"
              },
              "isfavourite": {
                "description": "Whether the user has marked this course as a favourite.",
                "example": false,
                "type": "boolean"
              },
              "hidden": {
                "description": "Whether the user has hidden this course from their dashboard.",
                "example": false,
                "type": "boolean"
              },
              "showshortname": {
                "description": "Whether the short name is displayed alongside the full name.",
                "example": false,
                "type": "boolean"
              },
              "coursecategory": {
                "description": "Name of the category this course belongs to.",
                "example": "2nd Semester (SP-2024)",
                "type": "string"
              }
            },
            "required": [
              "id",
              "fullname",
              "shortname",
              "idnumber",
              "summary",
              "summaryformat",
              "startdate",
              "enddate",
              "visible",
              "fullnamedisplay",
              "viewurl",
              "progress",
              "hasprogress",
              "isfavourite",
              "hidden",
              "showshortname",
              "coursecategory"
            ]
          }
        },
        "nextoffset": {
          "description": "Offset to pass on the next page request; -1 when no further pages exist.",
          "example": 29,
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "courses",
        "nextoffset"
      ]
    }
- EventIcon: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "EventIcon",
      "title": "EventIcon",
      "description": "Icon metadata for a calendar event.",
      "type": "object",
      "properties": {
        "key": {
          "description": "Icon key name used to locate the icon asset.",
          "example": "icon",
          "type": "string"
        },
        "component": {
          "description": "Moodle component that owns the icon (e.g., 'assign').",
          "example": "assign",
          "type": "string"
        },
        "alttext": {
          "description": "Accessible alt text for the icon image.",
          "example": "Activity event",
          "type": "string"
        }
      },
      "required": [
        "key",
        "component",
        "alttext"
      ]
    }
- EventSubscription: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "EventSubscription",
      "title": "EventSubscription",
      "description": "Subscription display settings for a calendar event.",
      "type": "object",
      "properties": {
        "displayeventsource": {
          "description": "Whether to display the event source label on the calendar.",
          "example": false,
          "type": "boolean"
        }
      },
      "required": [
        "displayeventsource"
      ]
    }
- EventAction: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "EventAction",
      "title": "EventAction",
      "description": "Primary action button metadata for a calendar event.",
      "type": "object",
      "properties": {
        "name": {
          "description": "Display label for the primary action button.",
          "example": "Add submission",
          "type": "string"
        },
        "url": {
          "description": "URL the user should navigate to in order to perform the action.",
          "example": "https://lms.nust.edu.pk/portal/mod/assign/view.php?id=999404&action=editsubmission",
          "type": "string"
        },
        "itemcount": {
          "description": "Number of items associated with this action.",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "actionable": {
          "description": "Whether the action can currently be taken by the user.",
          "example": true,
          "type": "boolean"
        },
        "showitemcount": {
          "description": "Whether to display the item count alongside the action label.",
          "example": false,
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "url",
        "itemcount",
        "actionable",
        "showitemcount"
      ]
    }
- CalendarEvent: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "CalendarEvent",
      "title": "CalendarEvent",
      "description": "A calendar action event tied to a course activity (e.g., an assignment deadline).",
      "type": "object",
      "properties": {
        "id": {
          "description": "Unique calendar event identifier.",
          "example": 149885,
          "type": "integer",
          "format": "int32"
        },
        "name": {
          "description": "Display name of the calendar event.",
          "example": "Lab 1 BSCS 13C is due",
          "type": "string"
        },
        "description": {
          "description": "HTML description body of the event.",
          "example": "<p dir=\"ltr\">Lab 1 BSCS 13C<br /></p>",
          "type": "string"
        },
        "descriptionformat": {
          "description": "Text format of the description (1 = HTML).",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "location": {
          "description": "Physical or virtual location of the event; empty string if not specified.",
          "type": "string"
        },
        "component": {
          "description": "Moodle component that created the event (e.g., 'mod_assign').",
          "example": "mod_assign",
          "type": "string"
        },
        "modulename": {
          "description": "Short name of the Moodle activity module (e.g., 'assign').",
          "example": "assign",
          "type": "string"
        },
        "instance": {
          "description": "The course module instance ID.",
          "example": 999404,
          "type": "integer",
          "format": "int32"
        },
        "eventtype": {
          "description": "Type of the event (e.g., 'due', 'open', 'close').",
          "example": "due",
          "type": "string"
        },
        "timestart": {
          "description": "Event start time as Unix timestamp.",
          "example": 1706900340,
          "type": "integer",
          "format": "int32"
        },
        "timeduration": {
          "description": "Duration in seconds; 0 for point-in-time events.",
          "example": 0,
          "type": "integer",
          "format": "int32"
        },
        "timesort": {
          "description": "Sort timestamp used for ordering events.",
          "example": 1706900340,
          "type": "integer",
          "format": "int32"
        },
        "visible": {
          "description": "Visibility flag for a calendar event. 1 means the event is visible; 0 means it is hidden.",
          "type": "integer",
          "format": "int32"
        },
        "timemodified": {
          "description": "Last modification time as Unix timestamp.",
          "example": 1779088440,
          "type": "integer",
          "format": "int32"
        },
        "icon": {
          "id": "EventIcon",
          "title": "EventIcon",
          "description": "Icon metadata for a calendar event.",
          "type": "object",
          "properties": {
            "key": {
              "description": "Icon key name used to locate the icon asset.",
              "example": "icon",
              "type": "string"
            },
            "component": {
              "description": "Moodle component that owns the icon (e.g., 'assign').",
              "example": "assign",
              "type": "string"
            },
            "alttext": {
              "description": "Accessible alt text for the icon image.",
              "example": "Activity event",
              "type": "string"
            }
          },
          "required": [
            "key",
            "component",
            "alttext"
          ]
        },
        "course": {
          "id": "Course",
          "title": "Course",
          "description": "An enrolled course.",
          "type": "object",
          "properties": {
            "id": {
              "description": "Unique course identifier.",
              "example": 49900,
              "type": "integer",
              "format": "int32"
            },
            "fullname": {
              "description": "Full display name of the course.",
              "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
              "type": "string"
            },
            "shortname": {
              "description": "Short course code or abbreviated name.",
              "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
              "type": "string"
            },
            "idnumber": {
              "description": "Institution-assigned course ID number; empty string if not set.",
              "type": "string"
            },
            "summary": {
              "description": "HTML summary of the course.",
              "type": "string"
            },
            "summaryformat": {
              "description": "Format of the summary field (1 = HTML).",
              "example": 1,
              "type": "integer",
              "format": "int32"
            },
            "startdate": {
              "description": "Course start date as Unix timestamp.",
              "example": 1706468400,
              "type": "integer",
              "format": "int32"
            },
            "enddate": {
              "description": "Course end date as Unix timestamp. 0 means no end date.",
              "example": 1717362000,
              "type": "integer",
              "format": "int32"
            },
            "visible": {
              "description": "Whether the course is visible to enrolled students.",
              "example": true,
              "type": "boolean"
            },
            "fullnamedisplay": {
              "description": "Display name of the course (may differ from fullname for context).",
              "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
              "type": "string"
            },
            "viewurl": {
              "description": "URL to the course page on the LMS portal.",
              "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
              "type": "string"
            },
            "progress": {
              "description": "Student's completion progress as a percentage.",
              "example": 21,
              "type": "integer",
              "minimum": 0.0,
              "maximum": 100.0,
              "format": "int32"
            },
            "hasprogress": {
              "description": "Whether completion tracking is enabled for this course.",
              "example": true,
              "type": "boolean"
            },
            "isfavourite": {
              "description": "Whether the user has marked this course as a favourite.",
              "example": false,
              "type": "boolean"
            },
            "hidden": {
              "description": "Whether the user has hidden this course from their dashboard.",
              "example": false,
              "type": "boolean"
            },
            "showshortname": {
              "description": "Whether the short name is displayed alongside the full name.",
              "example": false,
              "type": "boolean"
            },
            "coursecategory": {
              "description": "Name of the category this course belongs to.",
              "example": "2nd Semester (SP-2024)",
              "type": "string"
            }
          },
          "required": [
            "id",
            "fullname",
            "shortname",
            "idnumber",
            "summary",
            "summaryformat",
            "startdate",
            "enddate",
            "visible",
            "fullnamedisplay",
            "viewurl",
            "progress",
            "hasprogress",
            "isfavourite",
            "hidden",
            "showshortname",
            "coursecategory"
          ]
        },
        "subscription": {
          "id": "EventSubscription",
          "title": "EventSubscription",
          "description": "Subscription display settings for a calendar event.",
          "type": "object",
          "properties": {
            "displayeventsource": {
              "description": "Whether to display the event source label on the calendar.",
              "example": false,
              "type": "boolean"
            }
          },
          "required": [
            "displayeventsource"
          ]
        },
        "canedit": {
          "description": "Whether the current user can edit this event.",
          "example": false,
          "type": "boolean"
        },
        "candelete": {
          "description": "Whether the current user can delete this event.",
          "example": false,
          "type": "boolean"
        },
        "deleteurl": {
          "description": "URL to delete this calendar event.",
          "example": "https://lms.nust.edu.pk/portal/calendar/delete.php?id=149885&course=49900",
          "type": "string"
        },
        "editurl": {
          "description": "URL to edit the underlying course module associated with this event.",
          "example": "https://lms.nust.edu.pk/portal/course/mod.php?update=999404&return=1&sesskey=XXXX",
          "type": "string"
        },
        "viewurl": {
          "description": "URL to view this event on the calendar.",
          "example": "https://lms.nust.edu.pk/portal/calendar/view.php?view=day&course=49900&time=1706900340",
          "type": "string"
        },
        "formattedtime": {
          "description": "HTML-formatted human-readable event time string.",
          "example": "<span class=\"dimmed_text\">Friday, 2 February, 11:59 PM</span>",
          "type": "string"
        },
        "isactionevent": {
          "description": "Whether this is an action event requiring user interaction.",
          "example": true,
          "type": "boolean"
        },
        "iscourseevent": {
          "description": "Whether this event is associated with a specific course.",
          "example": false,
          "type": "boolean"
        },
        "iscategoryevent": {
          "description": "Whether this event is associated with a course category.",
          "example": false,
          "type": "boolean"
        },
        "normalisedeventtype": {
          "description": "Normalised event type identifier used for display grouping.",
          "example": "course",
          "type": "string"
        },
        "normalisedeventtypetext": {
          "description": "Human-readable label for the normalised event type.",
          "example": "Course event",
          "type": "string"
        },
        "url": {
          "description": "Direct URL to the course activity associated with this event.",
          "example": "https://lms.nust.edu.pk/portal/mod/assign/view.php?id=999404",
          "type": "string"
        },
        "categoryid": {
          "description": "Course category ID; null if not a category event.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "groupid": {
          "description": "Group ID if the event is group-specific; null otherwise.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "userid": {
          "description": "User ID if the event is user-specific; null otherwise.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "repeatid": {
          "description": "ID of the repeat group for recurring events; null if not recurring.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "eventcount": {
          "description": "Total number of events in the repeat group; null if not applicable.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        },
        "groupname": {
          "description": "Name of the group for group-specific events; null otherwise.",
          "type": [
            "string",
            "null"
          ]
        },
        "action": {
          "id": "EventAction",
          "title": "EventAction",
          "description": "Primary action button metadata for a calendar event.",
          "type": "object",
          "properties": {
            "name": {
              "description": "Display label for the primary action button.",
              "example": "Add submission",
              "type": "string"
            },
            "url": {
              "description": "URL the user should navigate to in order to perform the action.",
              "example": "https://lms.nust.edu.pk/portal/mod/assign/view.php?id=999404&action=editsubmission",
              "type": "string"
            },
            "itemcount": {
              "description": "Number of items associated with this action.",
              "example": 1,
              "type": "integer",
              "format": "int32"
            },
            "actionable": {
              "description": "Whether the action can currently be taken by the user.",
              "example": true,
              "type": "boolean"
            },
            "showitemcount": {
              "description": "Whether to display the item count alongside the action label.",
              "example": false,
              "type": "boolean"
            }
          },
          "required": [
            "name",
            "url",
            "itemcount",
            "actionable",
            "showitemcount"
          ]
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "descriptionformat",
        "location",
        "component",
        "modulename",
        "instance",
        "eventtype",
        "timestart",
        "timeduration",
        "timesort",
        "visible",
        "timemodified",
        "icon",
        "course",
        "subscription",
        "canedit",
        "candelete",
        "deleteurl",
        "editurl",
        "viewurl",
        "formattedtime",
        "isactionevent",
        "iscourseevent",
        "iscategoryevent",
        "normalisedeventtype",
        "normalisedeventtypetext",
        "url"
      ]
    }

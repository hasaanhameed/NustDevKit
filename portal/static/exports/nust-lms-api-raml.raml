                    "description": "Whether completion tracking is enabled for this course.",
                    "example": true,
                    "type": "boolean"
                  },
                  "isfavourite": {
                    "description": "Whether the user has marked this course as a favourite.",
                    "example": false,
                    "type": "boolean"
                  },
                  "hidden": {
                    "description": "Whether the user has hidden this course from their dashboard.",
                    "example": false,
                    "type": "boolean"
                  },
                  "showshortname": {
                    "description": "Whether the short name is displayed alongside the full name.",
                    "example": false,
                    "type": "boolean"
                  },
                  "coursecategory": {
                    "description": "Name of the category this course belongs to.",
                    "example": "2nd Semester (SP-2024)",
                    "type": "string"
                  }
                },
                "required": [
                  "id",
                  "fullname",
                  "shortname",
                  "idnumber",
                  "summary",
                  "summaryformat",
                  "startdate",
                  "enddate",
                  "visible",
                  "fullnamedisplay",
                  "viewurl",
                  "progress",
                  "hasprogress",
                  "isfavourite",
                  "hidden",
                  "showshortname",
                  "coursecategory"
                ]
              },
              "subscription": {
                "id": "EventSubscription",
                "title": "EventSubscription",
                "description": "Subscription display settings for a calendar event.",
                "type": "object",
                "properties": {
                  "displayeventsource": {
                    "description": "Whether to display the event source label on the calendar.",
                    "example": false,
                    "type": "boolean"
                  }
                },
                "required": [
                  "displayeventsource"
                ]
              },
              "canedit": {
                "description": "Whether the current user can edit this event.",
                "example": false,
                "type": "boolean"
              },
              "candelete": {
                "description": "Whether the current user can delete this event.",
                "example": false,
                "type": "boolean"
              },
              "deleteurl": {
                "description": "URL to delete this calendar event.",
                "example": "https://lms.nust.edu.pk/portal/calendar/delete.php?id=149885&course=49900",
                "type": "string"
              },
              "editurl": {
                "description": "URL to edit the underlying course module associated with this event.",
                "example": "https://lms.nust.edu.pk/portal/course/mod.php?update=999404&return=1&sesskey=XXXX",
                "type": "string"
              },
              "viewurl": {
                "description": "URL to view this event on the calendar.",
                "example": "https://lms.nust.edu.pk/portal/calendar/view.php?view=day&course=49900&time=1706900340",
                "type": "string"
              },
              "formattedtime": {
                "description": "HTML-formatted human-readable event time string.",
                "example": "<span class=\"dimmed_text\">Friday, 2 February, 11:59 PM</span>",
                "type": "string"
              },
              "isactionevent": {
                "description": "Whether this is an action event requiring user interaction.",
                "example": true,
                "type": "boolean"
              },
              "iscourseevent": {
                "description": "Whether this event is associated with a specific course.",
                "example": false,
                "type": "boolean"
              },
              "iscategoryevent": {
                "description": "Whether this event is associated with a course category.",
                "example": false,
                "type": "boolean"
              },
              "normalisedeventtype": {
                "description": "Normalised event type identifier used for display grouping.",
                "example": "course",
                "type": "string"
              },
              "normalisedeventtypetext": {
                "description": "Human-readable label for the normalised event type.",
                "example": "Course event",
                "type": "string"
              },
              "url": {
                "description": "Direct URL to the course activity associated with this event.",
                "example": "https://lms.nust.edu.pk/portal/mod/assign/view.php?id=999404",
                "type": "string"
              },
              "categoryid": {
                "description": "Course category ID; null if not a category event.",
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              },
              "groupid": {
                "description": "Group ID if the event is group-specific; null otherwise.",
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              },
              "userid": {
                "description": "User ID if the event is user-specific; null otherwise.",
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              },
              "repeatid": {
                "description": "ID of the repeat group for recurring events; null if not recurring.",
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              },
              "eventcount": {
                "description": "Total number of events in the repeat group; null if not applicable.",
                "type": [
                  "integer",
                  "null"
                ],
                "format": "int32"
              },
              "groupname": {
                "description": "Name of the group for group-specific events; null otherwise.",
                "type": [
                  "string",
                  "null"
                ]
              },
              "action": {
                "id": "EventAction",
                "title": "EventAction",
                "description": "Primary action button metadata for a calendar event.",
                "type": "object",
                "properties": {
                  "name": {
                    "description": "Display label for the primary action button.",
                    "example": "Add submission",
                    "type": "string"
                  },
                  "url": {
                    "description": "URL the user should navigate to in order to perform the action.",
                    "example": "https://lms.nust.edu.pk/portal/mod/assign/view.php?id=999404&action=editsubmission",
                    "type": "string"
                  },
                  "itemcount": {
                    "description": "Number of items associated with this action.",
                    "example": 1,
                    "type": "integer",
                    "format": "int32"
                  },
                  "actionable": {
                    "description": "Whether the action can currently be taken by the user.",
                    "example": true,
                    "type": "boolean"
                  },
                  "showitemcount": {
                    "description": "Whether to display the item count alongside the action label.",
                    "example": false,
                    "type": "boolean"
                  }
                },
                "required": [
                  "name",
                  "url",
                  "itemcount",
                  "actionable",
                  "showitemcount"
                ]
              }
            },
            "required": [
              "id",
              "name",
              "description",
              "descriptionformat",
              "location",
              "component",
              "modulename",
              "instance",
              "eventtype",
              "timestart",
              "timeduration",
              "timesort",
              "visible",
              "timemodified",
              "icon",
              "course",
              "subscription",
              "canedit",
              "candelete",
              "deleteurl",
              "editurl",
              "viewurl",
              "formattedtime",
              "isactionevent",
              "iscourseevent",
              "iscategoryevent",
              "normalisedeventtype",
              "normalisedeventtypetext",
              "url"
            ]
          }
        },
        "firstid": {
          "description": "Event ID of the first item in the result set.",
          "example": 149885,
          "type": "integer",
          "format": "int32"
        },
        "lastid": {
          "description": "Event ID of the last item in the result set.",
          "example": 151886,
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "events",
        "firstid",
        "lastid"
      ]
    }
- Notification: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "Notification",
      "title": "Notification",
      "description": "A popup notification message delivered to a user.",
      "type": "object",
      "properties": {
        "id": {
          "description": "Unique notification identifier.",
          "example": 4857819,
          "type": "integer",
          "format": "int32"
        },
        "useridfrom": {
          "description": "User ID of the sender.",
          "example": 234567,
          "type": "integer",
          "format": "int32"
        },
        "useridto": {
          "description": "User ID of the recipient.",
          "example": 123456,
          "type": "integer",
          "format": "int32"
        },
        "subject": {
          "description": "Subject line of the notification.",
          "example": "CS-101 Introduction to Computing: Lab 3 Submission Deadline",
          "type": "string"
        },
        "shortenedsubject": {
          "description": "Shortened version of the notification subject for compact display.",
          "example": "CS-101 Introduction to Computing: Lab 3 Submission Deadline",
          "type": "string"
        },
        "text": {
          "description": "Short HTML excerpt of the notification.",
          "example": "<p>John Doe posted in CS-101 Introduction to Computing...</p>",
          "type": "string"
        },
        "fullmessage": {
          "description": "Full plain-text body of the notification.",
          "type": "string"
        },
        "fullmessageformat": {
          "description": "Format identifier for fullmessagehtml (2 = Markdown source).",
          "example": 2,
          "type": "integer",
          "format": "int32"
        },
        "fullmessagehtml": {
          "description": "Full HTML body of the notification email.",
          "type": "string"
        },
        "smallmessage": {
          "description": "Short plain-text preview of the notification.",
          "example": "John Doe posted in CS-101 Introduction to Computing...",
          "type": "string"
        },
        "contexturl": {
          "description": "URL to the relevant context for this notification (e.g., a forum post).",
          "example": "https://lms.nust.edu.pk/portal/mod/forum/discuss.php?d=41767#p52342",
          "type": "string"
        },
        "contexturlname": {
          "description": "Human-readable label for the context URL link.",
          "example": "Lab Sessional Finalization - (DL - Section D & E)",
          "type": "string"
        },
        "timecreated": {
          "description": "Unix timestamp when the notification was created.",
          "example": 1780045085,
          "type": "integer",
          "format": "int32"
        },
        "timecreatedpretty": {
          "description": "Human-readable relative time string (e.g., '19 days ago').",
          "example": "19 days ago",
          "type": "string"
        },
        "read": {
          "description": "Whether the notification has been read by the recipient.",
          "example": false,
          "type": "boolean"
        },
        "deleted": {
          "description": "Whether the notification has been deleted by the recipient.",
          "example": false,
          "type": "boolean"
        },
        "iconurl": {
          "description": "URL to the icon image representing the notification source.",
          "example": "https://lms.nust.edu.pk/portal/theme/image.php/moove/mod_forum/1778048051/icon",
          "type": "string"
        },
        "component": {
          "description": "Moodle component that generated the notification (e.g., 'mod_forum').",
          "example": "mod_forum",
          "type": "string"
        },
        "eventtype": {
          "description": "Event type within the component that triggered the notification (e.g., 'posts').",
          "example": "posts",
          "type": "string"
        },
        "customdata": {
          "description": "JSON-encoded string with additional notification metadata (cmid, instance, discussionid, postid, etc.).",
          "example": {
            "cmid": "1272420",
            "instance": "62569",
            "discussionid": "41767"
          },
          "type": "string"
        },
        "timeread": {
          "description": "Unix timestamp when the notification was read; null if unread.",
          "type": [
            "integer",
            "null"
          ],
          "format": "int32"
        }
      },
      "required": [
        "id",
        "useridfrom",
        "useridto",
        "subject",
        "shortenedsubject",
        "text",
        "fullmessage",
        "fullmessageformat",
        "fullmessagehtml",
        "smallmessage",
        "contexturl",
        "contexturlname",
        "timecreated",
        "timecreatedpretty",
        "read",
        "deleted",
        "iconurl",
        "component",
        "eventtype",
        "customdata"
      ]
    }

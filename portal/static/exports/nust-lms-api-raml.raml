- AuthLogin401Error1: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "AuthLogin401Error1",
      "title": "AuthLogin401Error1",
      "type": "object",
      "properties": {
        "detail": {
          "example": "Invalid LMS credentials.",
          "type": "string"
        }
      }
    }
/auth/login:
  post:
    securedBy: []
    description: >
      Authenticates against NUST LMS on your behalf and returns a gateway JWT. The LMS session (cookie + sesskey) is created and held server-side; use the returned token as `Authorization: Bearer <token>` for every other operation.
    headers:
      Content-Type:
        required: true
        displayName: Content-Type
        enum:
        - application/json
    body:
      application/json:
        schema: |
          {
            "id": "LoginRequest",
            "title": "LoginRequest",
            "description": "NUST LMS credentials.",
            "type": "object",
            "properties": {
              "username": {
                "description": "NUST LMS username.",
                "example": "johndoe.bscs23seecs",
                "type": "string"
              },
              "password": {
                "description": "NUST LMS password.",
                "type": "string",
                "format": "password"
              }
            },
            "required": [
              "username",
              "password"
            ]
          }
        example: ''
    responses:
      '200':
        description: Authentication succeeded; bearer token issued.
        body:
          application/json:
            schema: |
              {
                "id": "TokenResponse",
                "title": "TokenResponse",
                "description": "Bearer token issued by the gateway after a successful login.",
                "type": "object",
                "properties": {
                  "access_token": {
                    "description": "JWT to send as `Authorization: Bearer <token>` on subsequent requests.",
                    "type": "string"
                  },
                  "token_type": {
                    "example": "bearer",
                    "type": "string"
                  }
                },
                "required": [
                  "access_token",
                  "token_type"
                ]
              }
      '401':
        description: Invalid LMS credentials.
        body:
          application/json:
            schema: |
              {
                "id": "AuthLogin401Error1",
                "title": "AuthLogin401Error1",
                "type": "object",
                "properties": {
                  "detail": {
                    "example": "Invalid LMS credentials.",
                    "type": "string"
                  }
                }
              }
/service:
  /core_course_get_recent_courses:
    get:
      description: >
        Returns the courses the authenticated user has accessed most recently, ordered by last access time.

        Moodle method: `core_course_get_recent_courses`
      queryParameters:
        limit:
          description: Maximum number of courses to return.
          type: integer
          default: '10'
          required: true
          displayName: limit
      responses:
        '200':
          description: List of recently accessed courses ordered by last access.
          body:
            application/json:
              schema: |
                {
                  "description": "Recently accessed courses ordered by last access time.",
                  "type": "array",
                  "items": {
                    "id": "RecentCourse",
                    "title": "RecentCourse",
                    "description": "A recently accessed course, extending Course with the last-access timestamp.",
                    "type": "object",
                    "properties": {
                      "id": {
                        "description": "Unique course identifier.",
                        "example": 49900,
                        "type": "integer",
                        "format": "int32"
                      },
                      "fullname": {
                        "description": "Full display name of the course.",
                        "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                        "type": "string"
                      },
                      "shortname": {
                        "description": "Short course code or abbreviated name.",
                        "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
                        "type": "string"
                      },
                      "idnumber": {
                        "description": "Institution-assigned course ID number; empty string if not set.",
                        "type": "string"
                      },
                      "summary": {
                        "description": "HTML summary of the course.",
                        "type": "string"
                      },
                      "summaryformat": {
                        "description": "Format of the summary field (1 = HTML).",
                        "example": 1,
                        "type": "integer",
                        "format": "int32"
                      },
                      "startdate": {
                        "description": "Course start date as Unix timestamp.",
                        "example": 1706468400,
                        "type": "integer",
                        "format": "int32"
                      },
                      "enddate": {
                        "description": "Course end date as Unix timestamp. 0 means no end date.",
                        "example": 1717362000,
                        "type": "integer",
                        "format": "int32"
                      },
                      "visible": {
                        "description": "Whether the course is visible to enrolled students.",
                        "example": true,
                        "type": "boolean"
                      },
                      "fullnamedisplay": {
                        "description": "Display name of the course (may differ from fullname for context).",
                        "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                        "type": "string"
                      },
                      "viewurl": {
                        "description": "URL to the course page on the LMS portal.",
                        "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
                        "type": "string"
                      },
                      "progress": {
                        "description": "Student's completion progress as a percentage.",
                        "example": 21,
                        "type": "integer",
                        "minimum": 0.0,
                        "maximum": 100.0,
                        "format": "int32"
                      },
                      "hasprogress": {
                        "description": "Whether completion tracking is enabled for this course.",
                        "example": true,
                        "type": "boolean"
                      },
                      "isfavourite": {
                        "description": "Whether the user has marked this course as a favourite.",
                        "example": false,
                        "type": "boolean"
                      },
                      "hidden": {
                        "description": "Whether the user has hidden this course from their dashboard.",
                        "example": false,
                        "type": "boolean"
                      },
                      "showshortname": {
                        "description": "Whether the short name is displayed alongside the full name.",
                        "example": false,
                        "type": "boolean"
                      },
                      "coursecategory": {
                        "description": "Name of the category this course belongs to.",
                        "example": "2nd Semester (SP-2024)",
                        "type": "string"
                      },
                      "timeaccess": {
                        "description": "Unix timestamp of the user's most recent access to this course.",
                        "example": 1781632422,
                        "type": "integer",
                        "format": "int32"
                      }
                    },
                    "required": [
                      "id",
                      "fullname",
                      "shortname",
                      "idnumber",
                      "summary",
                      "summaryformat",
                      "startdate",
                      "enddate",
                      "visible",
                      "fullnamedisplay",
                      "viewurl",
                      "progress",
                      "hasprogress",
                      "isfavourite",
                      "hidden",
                      "showshortname",
                      "coursecategory",
                      "timeaccess"
                    ]
                  }
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /core_course_get_enrolled_courses_by_timeline_classification:
    get:
      description: >
        Returns all courses the user is enrolled in, filtered by timeline classification and sorted by a chosen field. Supports pagination via offset.

        Moodle method: `core_course_get_enrolled_courses_by_timeline_classification`
      queryParameters:
        offset:
          description: Zero-based pagination offset.
          type: integer
          default: '0'
          required: true
          displayName: offset
        limit:
          description: Maximum number of courses to return.
          type: integer
          default: '50'
          required: true
          displayName: limit
        classification:
          description: Timeline classification filter for enrolled courses.
          required: true
          displayName: classification
          enum:
          - all
          - inprogress
          - past
          - future
          - favourites
          - hidden
          - allincludinghidden
        sort:
          description: Field used to sort enrolled course results.
          required: true
          displayName: sort
          enum:
          - fullname
          - shortname
          - id
          - idnumber
          - timeaccess
      responses:
        '200':
          description: Paginated list of enrolled courses.
          body:
            application/json:
              schema: |
                {
                  "id": "EnrolledCoursesResponse",
                  "title": "EnrolledCoursesResponse",
                  "description": "Paginated enrolled-courses response.",
                  "type": "object",
                  "properties": {
                    "courses": {
                      "description": "List of enrolled courses for the current page.",
                      "type": "array",
                      "items": {
                        "id": "Course",
                        "title": "Course",
                        "description": "An enrolled course.",
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "Unique course identifier.",
                            "example": 49900,
                            "type": "integer",
                            "format": "int32"
                          },
                          "fullname": {
                            "description": "Full display name of the course.",
                            "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                            "type": "string"
                          },
                          "shortname": {
                            "description": "Short course code or abbreviated name.",
                            "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
                            "type": "string"
                          },
                          "idnumber": {
                            "description": "Institution-assigned course ID number; empty string if not set.",
                            "type": "string"
                          },
                          "summary": {
                            "description": "HTML summary of the course.",
                            "type": "string"
                          },
                          "summaryformat": {
                            "description": "Format of the summary field (1 = HTML).",
                            "example": 1,
                            "type": "integer",
                            "format": "int32"
                          },
                          "startdate": {
                            "description": "Course start date as Unix timestamp.",
                            "example": 1706468400,
                            "type": "integer",
                            "format": "int32"
                          },
                          "enddate": {
                            "description": "Course end date as Unix timestamp. 0 means no end date.",
                            "example": 1717362000,
                            "type": "integer",
                            "format": "int32"
                          },
                          "visible": {
                            "description": "Whether the course is visible to enrolled students.",
                            "example": true,
                            "type": "boolean"
                          },
                          "fullnamedisplay": {
                            "description": "Display name of the course (may differ from fullname for context).",
                            "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                            "type": "string"
                          },
                          "viewurl": {
                            "description": "URL to the course page on the LMS portal.",
                            "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
                            "type": "string"
                          },
                          "progress": {
                            "description": "Student's completion progress as a percentage.",
                            "example": 21,
                            "type": "integer",
                            "minimum": 0.0,
                            "maximum": 100.0,
                            "format": "int32"
                          },
                          "hasprogress": {
                            "description": "Whether completion tracking is enabled for this course.",
                            "example": true,
                            "type": "boolean"
                          },
                          "isfavourite": {
                            "description": "Whether the user has marked this course as a favourite.",
                            "example": false,
                            "type": "boolean"
                          },
                          "hidden": {
                            "description": "Whether the user has hidden this course from their dashboard.",
                            "example": false,
                            "type": "boolean"
                          },
                          "showshortname": {
                            "description": "Whether the short name is displayed alongside the full name.",
                            "example": false,
                            "type": "boolean"
                          },
                          "coursecategory": {
                            "description": "Name of the category this course belongs to.",
                            "example": "2nd Semester (SP-2024)",
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "fullname",
                          "shortname",
                          "idnumber",
                          "summary",
                          "summaryformat",
                          "startdate",
                          "enddate",
                          "visible",
                          "fullnamedisplay",
                          "viewurl",
                          "progress",
                          "hasprogress",
                          "isfavourite",
                          "hidden",
                          "showshortname",
                          "coursecategory"
                        ]
                      }
                    },
                    "nextoffset": {
                      "description": "Offset to pass on the next page request; -1 when no further pages exist.",
                      "example": 29,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "courses",
                    "nextoffset"
                  ]
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /core_course_get_contents:
    get:
      description: >
        Returns the full content structure of a course — its sections (weeks/topics) and the modules within them (files, folders, pages, URLs, assignments, and other activities), including metadata for each uploaded file. This is the data the course page itself is built from.

        Note: file URLs point at Moodle's `pluginfile.php` and require authentication (a webservice token or the active session) to download — the URL alone is not publicly fetchable.

        Moodle method: `core_course_get_contents`
      queryParameters:
        courseid:
          description: ID of the course whose contents to retrieve.
          type: integer
          required: true
          displayName: courseid
      responses:
        '200':
          description: Course sections, each with its modules and their uploaded files.
          body:
            application/json:
              schema: |
                {
                  "description": "The course's sections, in display order.",
                  "type": "array",
                  "items": {
                    "id": "CourseSection",
                    "title": "CourseSection",
                    "description": "A section (week/topic) of the course, containing its modules.",
                    "type": "object",
                    "properties": {
                      "id": {
                        "description": "Section ID.",
                        "example": 33445,
                        "type": "integer",
                        "format": "int32"
                      },
                      "name": {
                        "description": "Section title (e.g. a week or topic name).",
                        "example": "Week 1",
                        "type": "string"
                      },
                      "section": {
                        "description": "Zero-based section number within the course.",
                        "example": 1,
                        "type": "integer",
                        "format": "int32"
                      },
                      "modules": {
                        "description": "The activities and resources in this section.",
                        "type": "array",
                        "items": {
                          "id": "CourseModule",
                          "title": "CourseModule",
                          "description": "An item on the course page — an activity or resource (file, page, URL, assignment, ...).",
                          "type": "object",
                          "properties": {
                            "id": {
                              "description": "Course module ID (cmid).",
                              "example": 987654,
                              "type": "integer",
                              "format": "int32"
                            },
                            "name": {
                              "description": "Display name of the module.",
                              "example": "Lecture 01 — Introduction",
                              "type": "string"
                            },
                            "modname": {
                              "description": "Module type, e.g. 'resource' (file), 'folder', 'url', 'page', 'label', 'assign', 'quiz', 'forum'.",
                              "example": "resource",
                              "type": "string"
                            },
                            "modplural": {
                              "description": "Human-readable plural label for the module type.",
                              "example": "Files",
                              "type": "string"
                            },
                            "instance": {
                              "description": "Instance ID of the activity within its module type.",
                              "example": 45678,
                              "type": "integer",
                              "format": "int32"
                            },
                            "description": {
                              "description": "HTML description/intro for the module, when present.",
                              "example": "<p>Course introduction and logistics.</p>",
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "visible": {
                              "description": "Whether the module is visible (1) or hidden (0).",
                              "example": 1,
                              "type": "integer",
                              "format": "int32"
                            },
                            "uservisible": {
                              "description": "Whether the module is visible to the current user.",
                              "example": true,
                              "type": "boolean"
                            },
                            "url": {
                              "description": "Link to open the activity/resource, when applicable.",
                              "example": "https://lms.nust.edu.pk/portal/mod/resource/view.php?id=987654",
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "modicon": {
                              "description": "URL of the module's type icon.",
                              "example": "https://lms.nust.edu.pk/portal/theme/image.php/moove/core/1/f/pdf",
                              "type": [
                                "string",
                                "null"
                              ]
                            },
                            "contents": {
                              "description": "Uploaded files/links for this module (present for resource/folder modules).",
                              "type": "array",
                              "items": {
                                "id": "CourseContentFile",
                                "title": "CourseContentFile",
                                "description": "A single file (or link) uploaded inside a course module.",
                                "type": "object",
                                "properties": {
                                  "type": {
                                    "description": "Content type, e.g. 'file' or 'url'.",
                                    "example": "file",
                                    "type": "string"
                                  },
                                  "filename": {
                                    "description": "Name of the file (or title of the link).",
                                    "example": "Lecture01-Intro.pdf",
                                    "type": "string"
                                  },
                                  "fileurl": {
                                    "description": "Moodle pluginfile.php URL for the content. Downloading the bytes requires authentication (a webservice token or the active session); the URL alone is not publicly fetchable.",
                                    "example": "https://lms.nust.edu.pk/portal/webservice/pluginfile.php/123456/mod_resource/content/1/Lecture01-Intro.pdf",
                                    "type": "string"
                                  },
                                  "filepath": {
                                    "description": "Folder path within the module; \"/\" for the module root.",
                                    "example": "/",
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  },
                                  "filesize": {
                                    "description": "File size in bytes (0 for links).",
                                    "example": 482133,
                                    "type": "integer",
                                    "format": "int32"
                                  },
                                  "mimetype": {
                                    "description": "MIME type of the file when applicable.",
                                    "example": "application/pdf",
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  },
                                  "timemodified": {
                                    "description": "Unix timestamp of the last modification.",
                                    "example": 1707745200,
                                    "type": "integer",
                                    "format": "int32"
                                  }
                                },
                                "required": [
                                  "type",
                                  "filename",
                                  "fileurl"
                                ]
                              }
                            }
                          },
                          "required": [
                            "id",
                            "name",
                            "modname"
                          ]
                        }
                      },
                      "visible": {
                        "description": "Whether the section is visible (1) or hidden (0).",
                        "example": 1,
                        "type": "integer",
                        "format": "int32"
                      },
                      "summary": {
                        "description": "HTML summary shown at the top of the section.",
                        "example": "<p>Introduction and course overview.</p>",
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "summaryformat": {
                        "description": "Moodle text format of the summary (1 = HTML).",
                        "example": 1,
                        "type": "integer",
                        "format": "int32"
                      },
                      "uservisible": {
                        "description": "Whether the section is visible to the current user.",
                        "example": true,
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "id",
                      "name",
                      "section",
                      "modules"
                    ]
                  }
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /core_calendar_get_action_events_by_timesort:
    get:
      description: >
        Returns action events (deadlines) across all enrolled courses, ordered by their sort timestamp. On NUST LMS these are submission due dates for assignments, labs, quizzes, and similar dated activities. Use `timesortfrom` to filter to upcoming deadlines only.

        Moodle method: `core_calendar_get_action_events_by_timesort`
      queryParameters:
        limitnum:
          description: Maximum number of events to return (e.g. 20 for one page of results).
          type: integer
          example: '20'
          required: true
          displayName: limitnum
        timesortfrom:
          description: Unix timestamp (seconds since epoch). Only events with a sort time at or after this value are returned. Pass `0` for no lower bound (all upcoming and past events). To see only upcoming deadlines, pass the current epoch time (e.g. the output of `Date.now() / 1000 | 0` in JS or `int(time.time())` in Python).
          type: integer
          example: '0'
          required: true
          displayName: timesortfrom
        timesortto:
          description: Only return events with timesort <= this Unix timestamp.
          type: integer
          required: false
          displayName: timesortto
        aftereventid:
          description: Return events whose ID is greater than this value (cursor pagination).
          type: integer
          required: false
          displayName: aftereventid
      responses:
        '200':
          description: Calendar events sorted by timesort.
          body:
            application/json:
              schema: |
                {
                  "id": "CalendarEventsResponse",
                  "title": "CalendarEventsResponse",
                  "description": "A list of calendar events with pagination boundary IDs.",
                  "type": "object",
                  "properties": {
                    "events": {
                      "description": "List of calendar action events for the current result set.",
                      "type": "array",
                      "items": {
                        "id": "CalendarEvent",
                        "title": "CalendarEvent",
                        "description": "A calendar action event. On NUST LMS these represent deadlines — the due date for an assignment, lab, quiz, or other submission tied to a course activity.",
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "Unique calendar event identifier.",
                            "example": 149885,
                            "type": "integer",
                            "format": "int32"
                          },
                          "name": {
                            "description": "Display name of the calendar event.",
                            "example": "Lab 1 BSCS 13C is due",
                            "type": "string"
                          },
                          "description": {
                            "description": "HTML description body of the event.",
                            "example": "<p dir=\"ltr\">Lab 1 BSCS 13C<br /></p>",
                            "type": "string"
                          },
                          "descriptionformat": {
                            "description": "Text format of the description (1 = HTML).",
                            "example": 1,
                            "type": "integer",
                            "format": "int32"
                          },
                          "location": {
                            "description": "Physical or virtual location of the event; empty string if not specified.",
                            "type": "string"
                          },
                          "component": {
                            "description": "Moodle component that created the event (e.g., 'mod_assign').",
                            "example": "mod_assign",
                            "type": "string"
                          },
                          "modulename": {
                            "description": "Short name of the Moodle activity module (e.g., 'assign').",
                            "example": "assign",
                            "type": "string"
                          },
                          "instance": {
                            "description": "The course module instance ID.",
                            "example": 999404,
                            "type": "integer",
                            "format": "int32"
                          },
                          "eventtype": {
                            "description": "Type of the event (e.g., 'due', 'open', 'close').",
                            "example": "due",
                            "type": "string"
                          },
                          "timestart": {
                            "description": "Event start time as Unix timestamp.",
                            "example": 1706900340,
                            "type": "integer",
                            "format": "int32"
                          },
                          "timeduration": {
                            "description": "Duration in seconds; 0 for point-in-time events.",
                            "example": 0,
                            "type": "integer",
                            "format": "int32"
                          },
                          "timesort": {
                            "description": "Sort timestamp used for ordering events.",
                            "example": 1706900340,
                            "type": "integer",
                            "format": "int32"
                          },
                          "visible": {
                            "description": "Visibility flag for a calendar event. 1 means the event is visible; 0 means it is hidden.",
                            "type": "integer",
                            "format": "int32"
                          },
                          "timemodified": {
                            "description": "Last modification time as Unix timestamp.",
                            "example": 1779088440,
                            "type": "integer",
                            "format": "int32"
                          },
                          "icon": {
                            "id": "EventIcon",
                            "title": "EventIcon",
                            "description": "Icon metadata for a calendar event.",
                            "type": "object",
                            "properties": {
                              "key": {
                                "description": "Icon key name used to locate the icon asset.",
                                "example": "icon",
                                "type": "string"
                              },
                              "component": {
                                "description": "Moodle component that owns the icon (e.g., 'assign').",
                                "example": "assign",
                                "type": "string"
                              },
                              "alttext": {
                                "description": "Accessible alt text for the icon image.",
                                "example": "Activity event",
                                "type": "string"
                              }
                            },
                            "required": [
                              "key",
                              "component",
                              "alttext"
                            ]
                          },
                          "course": {
                            "id": "Course",
                            "title": "Course",
                            "description": "An enrolled course.",
                            "type": "object",
                            "properties": {
                              "id": {
                                "description": "Unique course identifier.",
                                "example": 49900,
                                "type": "integer",
                                "format": "int32"
                              },
                              "fullname": {
                                "description": "Full display name of the course.",
                                "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                                "type": "string"
                              },
                              "shortname": {
                                "description": "Short course code or abbreviated name.",
                                "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
                                "type": "string"
                              },
                              "idnumber": {
                                "description": "Institution-assigned course ID number; empty string if not set.",
                                "type": "string"
                              },
                              "summary": {
                                "description": "HTML summary of the course.",
                                "type": "string"
                              },
                              "summaryformat": {
                                "description": "Format of the summary field (1 = HTML).",
                                "example": 1,
                                "type": "integer",
                                "format": "int32"
                              },
                              "startdate": {
                                "description": "Course start date as Unix timestamp.",
                                "example": 1706468400,
                                "type": "integer",
                                "format": "int32"
                              },
                              "enddate": {
                                "description": "Course end date as Unix timestamp. 0 means no end date.",
                                "example": 1717362000,
                                "type": "integer",
                                "format": "int32"
                              },
                              "visible": {
                                "description": "Whether the course is visible to enrolled students.",
                                "example": true,
                                "type": "boolean"
                              },
                              "fullnamedisplay": {
                                "description": "Display name of the course (may differ from fullname for context).",
                                "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                                "type": "string"
                              },
                              "viewurl": {
                                "description": "URL to the course page on the LMS portal.",
                                "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
                                "type": "string"
                              },
                              "progress": {
                                "description": "Student's completion progress as a percentage.",
                                "example": 21,
                                "type": "integer",
                                "minimum": 0.0,
                                "maximum": 100.0,
                                "format": "int32"
                              },
                              "hasprogress": {
                                "description": "Whether completion tracking is enabled for this course.",
                                "example": true,
                                "type": "boolean"
                              },
                              "isfavourite": {
                                "description": "Whether the user has marked this course as a favourite.",
                                "example": false,
                                "type": "boolean"
                              },
                              "hidden": {
                                "description": "Whether the user has hidden this course from their dashboard.",
                                "example": false,
                                "type": "boolean"
                              },
                              "showshortname": {
                                "description": "Whether the short name is displayed alongside the full name.",
                                "example": false,
                                "type": "boolean"
                              },
                              "coursecategory": {
                                "description": "Name of the category this course belongs to.",
                                "example": "2nd Semester (SP-2024)",
                                "type": "string"
                              }
                            },
                            "required": [
                              "id",
                              "fullname",
                              "shortname",
                              "idnumber",
                              "summary",
                              "summaryformat",
                              "startdate",
                              "enddate",
                              "visible",
                              "fullnamedisplay",
                              "viewurl",
                              "progress",
                              "hasprogress",
                              "isfavourite",
                              "hidden",
                              "showshortname",
                              "coursecategory"
                            ]
                          },
                          "subscription": {
                            "id": "EventSubscription",
                            "title": "EventSubscription",
                            "description": "Subscription display settings for a calendar event.",
                            "type": "object",
                            "properties": {
                              "displayeventsource": {
                                "description": "Whether to display the event source label on the calendar.",
                                "example": false,
                                "type": "boolean"
                              }
                            },
                            "required": [
                              "displayeventsource"
                            ]
                          },
                          "canedit": {
                            "description": "Whether the current user can edit this event.",
                            "example": false,
                            "type": "boolean"
                          },
                          "candelete": {
                            "description": "Whether the current user can delete this event.",
                            "example": false,
                            "type": "boolean"
                          },
                          "deleteurl": {
                            "description": "URL to delete this calendar event.",
                            "example": "https://lms.nust.edu.pk/portal/calendar/delete.php?id=149885&course=49900",
                            "type": "string"
                          },
                          "editurl": {
                            "description": "URL to edit the underlying course module associated with this event.",
                            "example": "https://lms.nust.edu.pk/portal/course/mod.php?update=999404&return=1&sesskey=XXXX",
                            "type": "string"
                          },
                          "viewurl": {
                            "description": "URL to view this event on the calendar.",
                            "example": "https://lms.nust.edu.pk/portal/calendar/view.php?view=day&course=49900&time=1706900340",
                            "type": "string"
                          },
                          "formattedtime": {
                            "description": "HTML-formatted human-readable event time string.",
                            "example": "<span class=\"dimmed_text\">Friday, 2 February, 11:59 PM</span>",
                            "type": "string"
                          },
                          "isactionevent": {
                            "description": "Whether this is an action event requiring user interaction.",
                            "example": true,
                            "type": "boolean"
                          },
                          "iscourseevent": {
                            "description": "Whether this event is associated with a specific course.",
                            "example": false,
                            "type": "boolean"
                          },
                          "iscategoryevent": {
                            "description": "Whether this event is associated with a course category.",
                            "example": false,
                            "type": "boolean"
                          },
                          "normalisedeventtype": {
                            "description": "Normalised event type identifier used for display grouping.",
                            "example": "course",
                            "type": "string"
                          },
                          "normalisedeventtypetext": {
                            "description": "Human-readable label for the normalised event type.",
                            "example": "Course event",
                            "type": "string"
                          },
                          "url": {
                            "description": "Direct URL to the course activity associated with this event.",
                            "example": "https://lms.nust.edu.pk/portal/mod/assign/view.php?id=999404",
                            "type": "string"
                          },
                          "categoryid": {
                            "description": "Course category ID; null if not a category event.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "groupid": {
                            "description": "Group ID if the event is group-specific; null otherwise.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "userid": {
                            "description": "User ID if the event is user-specific; null otherwise.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "repeatid": {
                            "description": "ID of the repeat group for recurring events; null if not recurring.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "eventcount": {
                            "description": "Total number of events in the repeat group; null if not applicable.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "groupname": {
                            "description": "Name of the group for group-specific events; null otherwise.",
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "action": {
                            "id": "EventAction",
                            "title": "EventAction",
                            "description": "Primary action button metadata for a calendar event.",
                            "type": "object",
                            "properties": {
                              "name": {
                                "description": "Display label for the primary action button.",
                                "example": "Add submission",
                                "type": "string"
                              },
                              "url": {
                                "description": "URL the user should navigate to in order to perform the action.",
                                "example": "https://lms.nust.edu.pk/portal/mod/assign/view.php?id=999404&action=editsubmission",
                                "type": "string"
                              },
                              "itemcount": {
                                "description": "Number of items associated with this action.",
                                "example": 1,
                                "type": "integer",
                                "format": "int32"
                              },
                              "actionable": {
                                "description": "Whether the action can currently be taken by the user.",
                                "example": true,
                                "type": "boolean"
                              },
                              "showitemcount": {
                                "description": "Whether to display the item count alongside the action label.",
                                "example": false,
                                "type": "boolean"
                              }
                            },
                            "required": [
                              "name",
                              "url",
                              "itemcount",
                              "actionable",
                              "showitemcount"
                            ]
                          }
                        },
                        "required": [
                          "id",
                          "name",
                          "description",
                          "descriptionformat",
                          "location",
                          "component",
                          "modulename",
                          "instance",
                          "eventtype",
                          "timestart",
                          "timeduration",
                          "timesort",
                          "visible",
                          "timemodified",
                          "icon",
                          "course",
                          "subscription",
                          "canedit",
                          "candelete",
                          "deleteurl",
                          "editurl",
                          "viewurl",
                          "formattedtime",
                          "isactionevent",
                          "iscourseevent",
                          "iscategoryevent",
                          "normalisedeventtype",
                          "normalisedeventtypetext",
                          "url"
                        ]
                      }
                    },
                    "firstid": {
                      "description": "Event ID of the first item in the result set.",
                      "example": 149885,
                      "type": "integer",
                      "format": "int32"
                    },
                    "lastid": {
                      "description": "Event ID of the last item in the result set.",
                      "example": 151886,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "events",
                    "firstid",
                    "lastid"
                  ]
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /core_calendar_get_action_events_by_course:
    get:
      description: >
        Returns all action events (deadlines) for a single course — assignment, lab, and quiz submission due dates, and other dated activities.

        Moodle method: `core_calendar_get_action_events_by_course`
      queryParameters:
        courseid:
          description: ID of the course to fetch events for.
          type: integer
          required: true
          displayName: courseid
        timesortfrom:
          description: Only return events with timesort >= this Unix timestamp.
          type: integer
          required: false
          displayName: timesortfrom
        timesortto:
          description: Only return events with timesort <= this Unix timestamp.
          type: integer
          required: false
          displayName: timesortto
        aftereventid:
          description: Cursor-based pagination — return events after this event ID.
          type: integer
          required: false
          displayName: aftereventid
        limitnum:
          description: Maximum number of events to return.
          type: integer
          required: false
          displayName: limitnum
      responses:
        '200':
          description: Calendar events for the specified course.
          body:
            application/json:
              schema: |
                {
                  "id": "CalendarEventsResponse",
                  "title": "CalendarEventsResponse",
                  "description": "A list of calendar events with pagination boundary IDs.",
                  "type": "object",
                  "properties": {
                    "events": {
                      "description": "List of calendar action events for the current result set.",
                      "type": "array",
                      "items": {
                        "id": "CalendarEvent",
                        "title": "CalendarEvent",
                        "description": "A calendar action event. On NUST LMS these represent deadlines — the due date for an assignment, lab, quiz, or other submission tied to a course activity.",
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "Unique calendar event identifier.",
                            "example": 149885,
                            "type": "integer",
                            "format": "int32"
                          },
                          "name": {
                            "description": "Display name of the calendar event.",
                            "example": "Lab 1 BSCS 13C is due",
                            "type": "string"
                          },
                          "description": {
                            "description": "HTML description body of the event.",
                            "example": "<p dir=\"ltr\">Lab 1 BSCS 13C<br /></p>",
                            "type": "string"
                          },
                          "descriptionformat": {
                            "description": "Text format of the description (1 = HTML).",
                            "example": 1,
                            "type": "integer",
                            "format": "int32"
                          },
                          "location": {
                            "description": "Physical or virtual location of the event; empty string if not specified.",
                            "type": "string"
                          },
                          "component": {
                            "description": "Moodle component that created the event (e.g., 'mod_assign').",
                            "example": "mod_assign",
                            "type": "string"
                          },
                          "modulename": {
                            "description": "Short name of the Moodle activity module (e.g., 'assign').",
                            "example": "assign",
                            "type": "string"
                          },
                          "instance": {
                            "description": "The course module instance ID.",
                            "example": 999404,
                            "type": "integer",
                            "format": "int32"
                          },
                          "eventtype": {
                            "description": "Type of the event (e.g., 'due', 'open', 'close').",
                            "example": "due",
                            "type": "string"
                          },
                          "timestart": {
                            "description": "Event start time as Unix timestamp.",
                            "example": 1706900340,
                            "type": "integer",
                            "format": "int32"
                          },
                          "timeduration": {
                            "description": "Duration in seconds; 0 for point-in-time events.",
                            "example": 0,
                            "type": "integer",
                            "format": "int32"
                          },
                          "timesort": {
                            "description": "Sort timestamp used for ordering events.",
                            "example": 1706900340,
                            "type": "integer",
                            "format": "int32"
                          },
                          "visible": {
                            "description": "Visibility flag for a calendar event. 1 means the event is visible; 0 means it is hidden.",
                            "type": "integer",
                            "format": "int32"
                          },
                          "timemodified": {
                            "description": "Last modification time as Unix timestamp.",
                            "example": 1779088440,
                            "type": "integer",
                            "format": "int32"
                          },
                          "icon": {
                            "id": "EventIcon",
                            "title": "EventIcon",
                            "description": "Icon metadata for a calendar event.",
                            "type": "object",
                            "properties": {
                              "key": {
                                "description": "Icon key name used to locate the icon asset.",
                                "example": "icon",
                                "type": "string"
                              },
                              "component": {
                                "description": "Moodle component that owns the icon (e.g., 'assign').",
                                "example": "assign",
                                "type": "string"
                              },
                              "alttext": {
                                "description": "Accessible alt text for the icon image.",
                                "example": "Activity event",
                                "type": "string"
                              }
                            },
                            "required": [
                              "key",
                              "component",
                              "alttext"
                            ]
                          },
                          "course": {
                            "id": "Course",
                            "title": "Course",
                            "description": "An enrolled course.",
                            "type": "object",

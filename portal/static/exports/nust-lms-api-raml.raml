                              "itemcount": {
                                "description": "Number of items associated with this action.",
                                "example": 1,
                                "type": "integer",
                                "format": "int32"
                              },
                              "actionable": {
                                "description": "Whether the action can currently be taken by the user.",
                                "example": true,
                                "type": "boolean"
                              },
                              "showitemcount": {
                                "description": "Whether to display the item count alongside the action label.",
                                "example": false,
                                "type": "boolean"
                              }
                            },
                            "required": [
                              "name",
                              "url",
                              "itemcount",
                              "actionable",
                              "showitemcount"
                            ]
                          }
                        },
                        "required": [
                          "id",
                          "name",
                          "description",
                          "descriptionformat",
                          "location",
                          "component",
                          "modulename",
                          "instance",
                          "eventtype",
                          "timestart",
                          "timeduration",
                          "timesort",
                          "visible",
                          "timemodified",
                          "icon",
                          "course",
                          "subscription",
                          "canedit",
                          "candelete",
                          "deleteurl",
                          "editurl",
                          "viewurl",
                          "formattedtime",
                          "isactionevent",
                          "iscourseevent",
                          "iscategoryevent",
                          "normalisedeventtype",
                          "normalisedeventtypetext",
                          "url"
                        ]
                      }
                    },
                    "firstid": {
                      "description": "Event ID of the first item in the result set.",
                      "example": 149885,
                      "type": "integer",
                      "format": "int32"
                    },
                    "lastid": {
                      "description": "Event ID of the last item in the result set.",
                      "example": 151886,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "events",
                    "firstid",
                    "lastid"
                  ]
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /core_fetch_notifications:
    get:
      description: >
        Returns pending site-level notifications for the given Moodle context. Returns an empty array when there are no pending notifications.

        Moodle method: `core_fetch_notifications`
      queryParameters:
        contextid:
          description: Moodle context ID for which to fetch notifications. The user context ID can be found in the user profile image URL path segment.
          type: integer
          required: true
          displayName: contextid
      responses:
        '200':
          description: Array of site notifications (empty array when none are pending).
          body:
            application/json:
              schema: |
                {
                  "description": "Site-level notifications for the given context; empty array when none are pending.",
                  "type": "array",
                  "items": {
                    "id": "SiteNotification",
                    "title": "SiteNotification",
                    "description": "A site-level notification (structure varies by type).",
                    "type": "object",
                    "properties": {
                      "id": {
                        "description": "Unique identifier for the site notification.",
                        "type": "integer",
                        "format": "int32"
                      },
                      "message": {
                        "description": "Notification message content.",
                        "type": "string"
                      },
                      "type": {
                        "description": "Notification type identifier.",
                        "type": "string"
                      }
                    }
                  }
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /message_popup_get_popup_notifications:
    get:
      description: >
        Returns the most recent popup notifications sent to a user, with support for pagination. Also returns the total count of unread notifications.

        Moodle method: `message_popup_get_popup_notifications`
      queryParameters:
        useridto:
          description: ID of the recipient user, passed as a string.
          type: string
          required: true
          displayName: useridto
        limit:
          description: Maximum number of notifications to return.
          type: integer
          required: true
          displayName: limit
        offset:
          description: Pagination offset.
          type: integer
          default: '0'
          required: true
          displayName: offset
      responses:
        '200':
          description: Popup notifications and total unread count.
          body:
            application/json:
              schema: |
                {
                  "id": "PopupNotificationsResponse",
                  "title": "PopupNotificationsResponse",
                  "description": "Response envelope for the popup-notifications endpoint.",
                  "type": "object",
                  "properties": {
                    "notifications": {
                      "description": "List of popup notifications for the user.",
                      "type": "array",
                      "items": {
                        "id": "Notification",
                        "title": "Notification",
                        "description": "A popup notification message delivered to a user.",
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "Unique notification identifier.",
                            "example": 4857819,
                            "type": "integer",
                            "format": "int32"
                          },
                          "useridfrom": {
                            "description": "User ID of the sender.",
                            "example": 234567,
                            "type": "integer",
                            "format": "int32"
                          },
                          "useridto": {
                            "description": "User ID of the recipient.",
                            "example": 123456,
                            "type": "integer",
                            "format": "int32"
                          },
                          "subject": {
                            "description": "Subject line of the notification.",
                            "example": "CS-101 Introduction to Computing: Lab 3 Submission Deadline",
                            "type": "string"
                          },
                          "shortenedsubject": {
                            "description": "Shortened version of the notification subject for compact display.",
                            "example": "CS-101 Introduction to Computing: Lab 3 Submission Deadline",
                            "type": "string"
                          },
                          "text": {
                            "description": "Short HTML excerpt of the notification.",
                            "example": "<p>John Doe posted in CS-101 Introduction to Computing...</p>",
                            "type": "string"
                          },
                          "fullmessage": {
                            "description": "Full plain-text body of the notification.",
                            "type": "string"
                          },
                          "fullmessageformat": {
                            "description": "Format identifier for fullmessagehtml (2 = Markdown source).",
                            "example": 2,
                            "type": "integer",
                            "format": "int32"
                          },
                          "fullmessagehtml": {
                            "description": "Full HTML body of the notification email.",
                            "type": "string"
                          },
                          "smallmessage": {
                            "description": "Short plain-text preview of the notification.",
                            "example": "John Doe posted in CS-101 Introduction to Computing...",
                            "type": "string"
                          },
                          "contexturl": {
                            "description": "URL to the relevant context for this notification (e.g., a forum post).",
                            "example": "https://lms.nust.edu.pk/portal/mod/forum/discuss.php?d=41767#p52342",
                            "type": "string"
                          },
                          "contexturlname": {
                            "description": "Human-readable label for the context URL link.",
                            "example": "Lab Sessional Finalization - (DL - Section D & E)",
                            "type": "string"
                          },
                          "timecreated": {
                            "description": "Unix timestamp when the notification was created.",
                            "example": 1780045085,
                            "type": "integer",
                            "format": "int32"
                          },
                          "timecreatedpretty": {
                            "description": "Human-readable relative time string (e.g., '19 days ago').",
                            "example": "19 days ago",
                            "type": "string"
                          },
                          "read": {
                            "description": "Whether the notification has been read by the recipient.",
                            "example": false,
                            "type": "boolean"
                          },
                          "deleted": {
                            "description": "Whether the notification has been deleted by the recipient.",
                            "example": false,
                            "type": "boolean"
                          },
                          "iconurl": {
                            "description": "URL to the icon image representing the notification source.",
                            "example": "https://lms.nust.edu.pk/portal/theme/image.php/moove/mod_forum/1778048051/icon",
                            "type": "string"
                          },
                          "component": {
                            "description": "Moodle component that generated the notification (e.g., 'mod_forum').",
                            "example": "mod_forum",
                            "type": "string"
                          },
                          "eventtype": {
                            "description": "Event type within the component that triggered the notification (e.g., 'posts').",
                            "example": "posts",
                            "type": "string"
                          },
                          "customdata": {
                            "description": "JSON-encoded string with additional notification metadata (cmid, instance, discussionid, postid, etc.).",
                            "example": {
                              "cmid": "1272420",
                              "instance": "62569",
                              "discussionid": "41767"
                            },
                            "type": "string"
                          },
                          "timeread": {
                            "description": "Unix timestamp when the notification was read; null if unread.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          }
                        },
                        "required": [
                          "id",
                          "useridfrom",
                          "useridto",
                          "subject",
                          "shortenedsubject",
                          "text",
                          "fullmessage",
                          "fullmessageformat",
                          "fullmessagehtml",
                          "smallmessage",
                          "contexturl",
                          "contexturlname",
                          "timecreated",
                          "timecreatedpretty",
                          "read",
                          "deleted",
                          "iconurl",
                          "component",
                          "eventtype",
                          "customdata"
                        ]
                      }
                    },
                    "unreadcount": {
                      "description": "Total number of unread notifications for the user.",
                      "example": 1,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "notifications",
                    "unreadcount"
                  ]
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }

#%RAML 0.8
title: NUST LMS API
version: 1.0.0
documentation:
- title: NUST LMS API
  content: |
    NUST Learning Management System API for developer integrations (Moodle AJAX wrapper).

    Authenticate with your NUST LMS credentials via `POST /auth/login` to receive a bearer token, then call any operation with `Authorization: Bearer <token>`. The NustDevKit gateway logs into the LMS on your behalf and manages the underlying session (cookie + sesskey) server-side, so you never handle the ephemeral sesskey.
baseUri: http://127.0.0.1:8000
securedBy:
- BearerAuth
protocols:
- HTTP
baseUriParameters: {}
schemas:
- LoginRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "LoginRequest",
      "title": "LoginRequest",
      "description": "NUST LMS credentials used to obtain a gateway bearer token.",
      "type": "object",
      "properties": {
        "username": {
          "description": "NUST LMS username.",
          "example": "johndoe.bscs23seecs",
          "type": "string"
        },
        "password": {
          "description": "NUST LMS password.",
          "type": "string",
          "format": "password"
        }
      },
      "required": [
        "username",
        "password"
      ]
    }
- TokenResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "TokenResponse",
      "title": "TokenResponse",
      "description": "Bearer token issued by the gateway after a successful login.",
      "type": "object",
      "properties": {
        "access_token": {
          "description": "JWT to send as `Authorization: Bearer <token>` on subsequent requests.",
          "type": "string"
        },
        "token_type": {
          "example": "bearer",
          "type": "string"
        }
      },
      "required": [
        "access_token",
        "token_type"
      ]
    }
- CourseTimelineClassification: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "title": "CourseTimelineClassification",
      "description": "Timeline classification filter for enrolled courses.",
      "type": "string",
      "additionalProperties": false,
      "enum": [
        "all",
        "inprogress",
        "past",
        "future",
        "favourites",
        "hidden",
        "allincludinghidden"
      ]
    }
- CourseTimelineSortField: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "title": "CourseTimelineSortField",
      "description": "Field used to sort enrolled course results.",
      "type": "string",
      "additionalProperties": false,
      "enum": [
        "fullname",
        "shortname",
        "id",
        "idnumber",
        "timeaccess"
      ]
    }
- MoodleWarning: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "MoodleWarning",
      "title": "MoodleWarning",
      "description": "A non-fatal warning returned alongside a successful response.",
      "type": "object",
      "properties": {
        "item": {
          "description": "Item identifier related to the warning; empty string if not applicable.",
          "type": "string"
        },
        "itemid": {
          "description": "Numeric item ID related to the warning; 0 if not applicable.",
          "example": 0,
          "type": "integer",
          "format": "int32"
        },
        "warningcode": {
          "description": "Machine-readable warning code; empty string if no code.",
          "type": "string"
        },
        "message": {
          "description": "Human-readable warning description.",
          "type": "string"
        }
      }
    }
- SiteNotification: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "SiteNotification",
      "title": "SiteNotification",
      "description": "A site-level notification (structure varies by type).",
      "type": "object",
      "properties": {
        "id": {
          "description": "Unique identifier for the site notification.",
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "description": "Notification message content.",
          "type": "string"
        },
        "type": {
          "description": "Notification type identifier.",
          "type": "string"
        }
      }
    }
- MoodleError: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "MoodleError",
      "title": "MoodleError",
      "description": "Error returned by the LMS on a failed operation.",
      "type": "object",
      "properties": {
        "errorcode": {
          "description": "Machine-readable error code identifier.",
          "example": "invalidrecord",
          "type": "string"
        },
        "message": {
          "description": "Human-readable error description.",
          "example": "Can't find data record in database table.",
          "type": "string"
        },
        "link": {
          "description": "Redirect URL for the user; empty string if not applicable.",
          "type": "string"
        },
        "moreinfourl": {
          "description": "URL to additional error documentation; empty string if not available.",
          "type": "string"
        },
        "debuginfo": {
          "description": "Additional debug information; empty string when not in debug mode.",
          "type": "string"
        }
      }
    }
- Course: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "Course",
      "title": "Course",
      "description": "An enrolled course.",
      "type": "object",
      "properties": {
        "id": {
          "description": "Unique course identifier.",
          "example": 49900,
          "type": "integer",
          "format": "int32"
        },
        "fullname": {
          "description": "Full display name of the course.",
          "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
          "type": "string"
        },
        "shortname": {
          "description": "Short course code or abbreviated name.",
          "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
          "type": "string"
        },
        "idnumber": {
          "description": "Institution-assigned course ID number; empty string if not set.",
          "type": "string"
        },
        "summary": {
          "description": "HTML summary of the course.",
          "type": "string"
        },
        "summaryformat": {
          "description": "Format of the summary field (1 = HTML).",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "startdate": {
          "description": "Course start date as Unix timestamp.",
          "example": 1706468400,
          "type": "integer",
          "format": "int32"
        },
        "enddate": {
          "description": "Course end date as Unix timestamp. 0 means no end date.",
          "example": 1717362000,
          "type": "integer",
          "format": "int32"
        },
        "visible": {
          "description": "Whether the course is visible to enrolled students.",
          "example": true,
          "type": "boolean"
        },
        "fullnamedisplay": {
          "description": "Display name of the course (may differ from fullname for context).",
          "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
          "type": "string"
        },
        "viewurl": {
          "description": "URL to the course page on the LMS portal.",
          "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
          "type": "string"
        },
        "progress": {
          "description": "Student's completion progress as a percentage.",
          "example": 21,
          "type": "integer",
          "minimum": 0.0,
          "maximum": 100.0,
          "format": "int32"
        },
        "hasprogress": {
          "description": "Whether completion tracking is enabled for this course.",
          "example": true,
          "type": "boolean"
        },
        "isfavourite": {
          "description": "Whether the user has marked this course as a favourite.",
          "example": false,
          "type": "boolean"
        },
        "hidden": {
          "description": "Whether the user has hidden this course from their dashboard.",
          "example": false,
          "type": "boolean"
        },
        "showshortname": {
          "description": "Whether the short name is displayed alongside the full name.",
          "example": false,
          "type": "boolean"
        },
        "coursecategory": {
          "description": "Name of the category this course belongs to.",
          "example": "2nd Semester (SP-2024)",
          "type": "string"
        }
      },
      "required": [
        "id",
        "fullname",
        "shortname",
        "idnumber",
        "summary",
        "summaryformat",
        "startdate",
        "enddate",
        "visible",
        "fullnamedisplay",
        "viewurl",
        "progress",
        "hasprogress",
        "isfavourite",
        "hidden",
        "showshortname",
        "coursecategory"
      ]
    }
- RecentCourseFields: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "RecentCourseFields",
      "title": "RecentCourseFields",
      "description": "Additional fields specific to recently accessed courses.",
      "type": "object",
      "properties": {
        "timeaccess": {
          "description": "Unix timestamp of the user's most recent access to this course.",
          "example": 1781632422,
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "timeaccess"
      ]
    }
- RecentCourse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "RecentCourse",
      "title": "RecentCourse",
      "description": "A recently accessed course, extending Course with the last-access timestamp.",
      "type": "object",
      "properties": {
        "id": {
          "description": "Unique course identifier.",
          "example": 49900,
          "type": "integer",
          "format": "int32"
        },
        "fullname": {
          "description": "Full display name of the course.",
          "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
          "type": "string"
        },
        "shortname": {
          "description": "Short course code or abbreviated name.",
          "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
          "type": "string"
        },
        "idnumber": {
          "description": "Institution-assigned course ID number; empty string if not set.",
          "type": "string"
        },
        "summary": {
          "description": "HTML summary of the course.",
          "type": "string"
        },
        "summaryformat": {
          "description": "Format of the summary field (1 = HTML).",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "startdate": {
          "description": "Course start date as Unix timestamp.",
          "example": 1706468400,
          "type": "integer",
          "format": "int32"
        },
        "enddate": {
          "description": "Course end date as Unix timestamp. 0 means no end date.",
          "example": 1717362000,
          "type": "integer",
          "format": "int32"
        },
        "visible": {
          "description": "Whether the course is visible to enrolled students.",
          "example": true,
          "type": "boolean"
        },
        "fullnamedisplay": {
          "description": "Display name of the course (may differ from fullname for context).",
          "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
          "type": "string"
        },
        "viewurl": {
          "description": "URL to the course page on the LMS portal.",
          "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
          "type": "string"
        },
        "progress": {
          "description": "Student's completion progress as a percentage.",
          "example": 21,
          "type": "integer",
          "minimum": 0.0,
          "maximum": 100.0,
          "format": "int32"
        },
        "hasprogress": {
          "description": "Whether completion tracking is enabled for this course.",
          "example": true,
          "type": "boolean"
        },
        "isfavourite": {
          "description": "Whether the user has marked this course as a favourite.",
          "example": false,
          "type": "boolean"
        },
        "hidden": {
          "description": "Whether the user has hidden this course from their dashboard.",
          "example": false,
          "type": "boolean"
        },
        "showshortname": {
          "description": "Whether the short name is displayed alongside the full name.",
          "example": false,
          "type": "boolean"
        },
        "coursecategory": {
          "description": "Name of the category this course belongs to.",
          "example": "2nd Semester (SP-2024)",
          "type": "string"
        },
        "timeaccess": {
          "description": "Unix timestamp of the user's most recent access to this course.",
          "example": 1781632422,
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "id",
        "fullname",
        "shortname",
        "idnumber",
        "summary",
        "summaryformat",
        "startdate",
        "enddate",
        "visible",
        "fullnamedisplay",
        "viewurl",
        "progress",
        "hasprogress",
        "isfavourite",
        "hidden",
        "showshortname",
        "coursecategory",
        "timeaccess"
      ]
    }
- EnrolledCoursesResponse: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "EnrolledCoursesResponse",
      "title": "EnrolledCoursesResponse",
      "description": "Paginated enrolled-courses response.",
      "type": "object",
      "properties": {
        "courses": {
          "description": "List of enrolled courses for the current page.",
          "type": "array",
          "items": {
            "id": "Course",
            "title": "Course",
            "description": "An enrolled course.",
            "type": "object",
            "properties": {
              "id": {
                "description": "Unique course identifier.",
                "example": 49900,
                "type": "integer",
                "format": "int32"
              },
              "fullname": {
                "description": "Full display name of the course.",
                "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                "type": "string"
              },
              "shortname": {
                "description": "Short course code or abbreviated name.",
                "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
                "type": "string"
              },
              "idnumber": {
                "description": "Institution-assigned course ID number; empty string if not set.",
                "type": "string"
              },
              "summary": {
                "description": "HTML summary of the course.",
                "type": "string"
              },
              "summaryformat": {
                "description": "Format of the summary field (1 = HTML).",
                "example": 1,
                "type": "integer",
                "format": "int32"
              },
              "startdate": {
                "description": "Course start date as Unix timestamp.",
                "example": 1706468400,
                "type": "integer",
                "format": "int32"
              },
              "enddate": {
                "description": "Course end date as Unix timestamp. 0 means no end date.",
                "example": 1717362000,
                "type": "integer",
                "format": "int32"
              },
              "visible": {
                "description": "Whether the course is visible to enrolled students.",
                "example": true,
                "type": "boolean"
              },
              "fullnamedisplay": {
                "description": "Display name of the course (may differ from fullname for context).",
                "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                "type": "string"
              },
              "viewurl": {
                "description": "URL to the course page on the LMS portal.",
                "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
                "type": "string"
              },
              "progress": {
                "description": "Student's completion progress as a percentage.",
                "example": 21,
                "type": "integer",
                "minimum": 0.0,
                "maximum": 100.0,
                "format": "int32"
              },
              "hasprogress": {
                "description": "Whether completion tracking is enabled for this course.",
                "example": true,
                "type": "boolean"
              },
              "isfavourite": {
                "description": "Whether the user has marked this course as a favourite.",
                "example": false,
                "type": "boolean"
              },
              "hidden": {
                "description": "Whether the user has hidden this course from their dashboard.",
                "example": false,
                "type": "boolean"
              },
              "showshortname": {
                "description": "Whether the short name is displayed alongside the full name.",
                "example": false,
                "type": "boolean"
              },
              "coursecategory": {
                "description": "Name of the category this course belongs to.",
                "example": "2nd Semester (SP-2024)",
                "type": "string"
              }
            },
            "required": [
              "id",
              "fullname",
              "shortname",
              "idnumber",
              "summary",
              "summaryformat",
              "startdate",
              "enddate",
              "visible",
              "fullnamedisplay",
              "viewurl",
              "progress",
              "hasprogress",
              "isfavourite",
              "hidden",
              "showshortname",
              "coursecategory"
            ]
          }
        },
        "nextoffset": {
          "description": "Offset to pass on the next page request; -1 when no further pages exist.",
          "example": 29,
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "courses",
        "nextoffset"
      ]
    }
- CourseContentFile: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "CourseContentFile",
      "title": "CourseContentFile",
      "description": "A single file (or link) uploaded inside a course module.",
      "type": "object",
      "properties": {
        "type": {
          "description": "Content type, e.g. 'file' or 'url'.",
          "example": "file",
          "type": "string"
        },
        "filename": {
          "description": "Name of the file (or title of the link).",
          "example": "Lecture01-Intro.pdf",
          "type": "string"
        },
        "fileurl": {
          "description": "Moodle pluginfile.php URL for the content. Downloading the bytes requires authentication (a webservice token or the active session); the URL alone is not publicly fetchable.",
          "example": "https://lms.nust.edu.pk/portal/webservice/pluginfile.php/123456/mod_resource/content/1/Lecture01-Intro.pdf",
          "type": "string"
        },
        "filepath": {
          "description": "Folder path within the module; \"/\" for the module root.",
          "example": "/",
          "type": [
            "string",
            "null"
          ]
        },
        "filesize": {
          "description": "File size in bytes (0 for links).",
          "example": 482133,
          "type": "integer",
          "format": "int32"
        },
        "mimetype": {
          "description": "MIME type of the file when applicable.",
          "example": "application/pdf",
          "type": [
            "string",
            "null"
          ]
        },
        "timemodified": {
          "description": "Unix timestamp of the last modification.",
          "example": 1707745200,
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "type",
        "filename",
        "fileurl"
      ]
    }
- CourseModule: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "CourseModule",
      "title": "CourseModule",
      "description": "An item on the course page — an activity or resource (file, page, URL, assignment, ...).",
      "type": "object",
      "properties": {
        "id": {
          "description": "Course module ID (cmid).",
          "example": 987654,
          "type": "integer",
          "format": "int32"
        },
        "name": {
          "description": "Display name of the module.",
          "example": "Lecture 01 — Introduction",
          "type": "string"
        },
        "modname": {
          "description": "Module type, e.g. 'resource' (file), 'folder', 'url', 'page', 'label', 'assign', 'quiz', 'forum'.",
          "example": "resource",
          "type": "string"
        },
        "modplural": {
          "description": "Human-readable plural label for the module type.",
          "example": "Files",
          "type": "string"
        },
        "instance": {
          "description": "Instance ID of the activity within its module type.",
          "example": 45678,
          "type": "integer",
          "format": "int32"
        },
        "description": {
          "description": "HTML description/intro for the module, when present.",
          "example": "<p>Course introduction and logistics.</p>",
          "type": [
            "string",
            "null"
          ]
        },
        "visible": {
          "description": "Whether the module is visible (1) or hidden (0).",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "uservisible": {
          "description": "Whether the module is visible to the current user.",
          "example": true,
          "type": "boolean"
        },
        "url": {
          "description": "Link to open the activity/resource, when applicable.",
          "example": "https://lms.nust.edu.pk/portal/mod/resource/view.php?id=987654",
          "type": [
            "string",
            "null"
          ]
        },
        "modicon": {
          "description": "URL of the module's type icon.",
          "example": "https://lms.nust.edu.pk/portal/theme/image.php/moove/core/1/f/pdf",
          "type": [
            "string",
            "null"
          ]
        },
        "contents": {
          "description": "Uploaded files/links for this module (present for resource/folder modules).",
          "type": "array",
          "items": {
            "id": "CourseContentFile",
            "title": "CourseContentFile",
            "description": "A single file (or link) uploaded inside a course module.",
            "type": "object",
            "properties": {
              "type": {
                "description": "Content type, e.g. 'file' or 'url'.",
                "example": "file",
                "type": "string"
              },
              "filename": {
                "description": "Name of the file (or title of the link).",
                "example": "Lecture01-Intro.pdf",
                "type": "string"
              },
              "fileurl": {
                "description": "Moodle pluginfile.php URL for the content. Downloading the bytes requires authentication (a webservice token or the active session); the URL alone is not publicly fetchable.",
                "example": "https://lms.nust.edu.pk/portal/webservice/pluginfile.php/123456/mod_resource/content/1/Lecture01-Intro.pdf",
                "type": "string"
              },
              "filepath": {
                "description": "Folder path within the module; \"/\" for the module root.",
                "example": "/",
                "type": [
                  "string",
                  "null"
                ]
              },
              "filesize": {
                "description": "File size in bytes (0 for links).",
                "example": 482133,
                "type": "integer",
                "format": "int32"
              },
              "mimetype": {
                "description": "MIME type of the file when applicable.",
                "example": "application/pdf",
                "type": [
                  "string",
                  "null"
                ]
              },
              "timemodified": {
                "description": "Unix timestamp of the last modification.",
                "example": 1707745200,
                "type": "integer",
                "format": "int32"
              }
            },
            "required": [
              "type",
              "filename",
              "fileurl"
            ]
          }
        }
      },
      "required": [
        "id",
        "name",
        "modname"
      ]
    }
- CourseSection: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "CourseSection",
      "title": "CourseSection",
      "description": "A section (week/topic) of the course, containing its modules.",
      "type": "object",
      "properties": {
        "id": {
          "description": "Section ID.",
          "example": 33445,
          "type": "integer",
          "format": "int32"
        },
        "name": {
          "description": "Section title (e.g. a week or topic name).",
          "example": "Week 1",
          "type": "string"
        },
        "section": {
          "description": "Zero-based section number within the course.",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "modules": {
          "description": "The activities and resources in this section.",
          "type": "array",
          "items": {
            "id": "CourseModule",
            "title": "CourseModule",
            "description": "An item on the course page — an activity or resource (file, page, URL, assignment, ...).",
            "type": "object",
            "properties": {
              "id": {
                "description": "Course module ID (cmid).",
                "example": 987654,
                "type": "integer",
                "format": "int32"
              },
              "name": {
                "description": "Display name of the module.",
                "example": "Lecture 01 — Introduction",
                "type": "string"
              },
              "modname": {
                "description": "Module type, e.g. 'resource' (file), 'folder', 'url', 'page', 'label', 'assign', 'quiz', 'forum'.",
                "example": "resource",
                "type": "string"
              },
              "modplural": {
                "description": "Human-readable plural label for the module type.",
                "example": "Files",
                "type": "string"
              },
              "instance": {
                "description": "Instance ID of the activity within its module type.",
                "example": 45678,
                "type": "integer",
                "format": "int32"
              },
              "description": {
                "description": "HTML description/intro for the module, when present.",
                "example": "<p>Course introduction and logistics.</p>",
                "type": [
                  "string",
                  "null"
                ]
              },
              "visible": {
                "description": "Whether the module is visible (1) or hidden (0).",
                "example": 1,
                "type": "integer",
                "format": "int32"
              },
              "uservisible": {
                "description": "Whether the module is visible to the current user.",
                "example": true,
                "type": "boolean"
              },
              "url": {
                "description": "Link to open the activity/resource, when applicable.",
                "example": "https://lms.nust.edu.pk/portal/mod/resource/view.php?id=987654",
                "type": [
                  "string",
                  "null"
                ]
              },
              "modicon": {
                "description": "URL of the module's type icon.",
                "example": "https://lms.nust.edu.pk/portal/theme/image.php/moove/core/1/f/pdf",
                "type": [
                  "string",
                  "null"
                ]
              },
              "contents": {
                "description": "Uploaded files/links for this module (present for resource/folder modules).",
                "type": "array",
                "items": {
                  "id": "CourseContentFile",
                  "title": "CourseContentFile",
                  "description": "A single file (or link) uploaded inside a course module.",
                  "type": "object",
                  "properties": {
                    "type": {
                      "description": "Content type, e.g. 'file' or 'url'.",
                      "example": "file",
                      "type": "string"
                    },
                    "filename": {
                      "description": "Name of the file (or title of the link).",
                      "example": "Lecture01-Intro.pdf",
                      "type": "string"
                    },
                    "fileurl": {
                      "description": "Moodle pluginfile.php URL for the content. Downloading the bytes requires authentication (a webservice token or the active session); the URL alone is not publicly fetchable.",
                      "example": "https://lms.nust.edu.pk/portal/webservice/pluginfile.php/123456/mod_resource/content/1/Lecture01-Intro.pdf",
                      "type": "string"
                    },
                    "filepath": {
                      "description": "Folder path within the module; \"/\" for the module root.",
                      "example": "/",
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "filesize": {
                      "description": "File size in bytes (0 for links).",
                      "example": 482133,
                      "type": "integer",
                      "format": "int32"
                    },
                    "mimetype": {
                      "description": "MIME type of the file when applicable.",
                      "example": "application/pdf",
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "timemodified": {
                      "description": "Unix timestamp of the last modification.",
                      "example": 1707745200,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "type",
                    "filename",
                    "fileurl"
                  ]
                }
              }
            },
            "required": [
              "id",
              "name",
              "modname"
            ]
          }
        },
        "visible": {
          "description": "Whether the section is visible (1) or hidden (0).",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "summary": {
          "description": "HTML summary shown at the top of the section.",
          "example": "<p>Introduction and course overview.</p>",
          "type": [
            "string",
            "null"
          ]
        },
        "summaryformat": {
          "description": "Moodle text format of the summary (1 = HTML).",
          "example": 1,
          "type": "integer",
          "format": "int32"
        },
        "uservisible": {
          "description": "Whether the section is visible to the current user.",
          "example": true,
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "name",
        "section",
        "modules"
      ]
    }
- EventIcon: |

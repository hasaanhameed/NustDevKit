- AuthLogin401Error1: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "AuthLogin401Error1",
      "title": "AuthLogin401Error1",
      "type": "object",
      "properties": {
        "detail": {
          "example": "Invalid LMS credentials.",
          "type": "string"
        }
      }
    }
/auth/login:
  post:
    securedBy: []
    description: >
      Authenticates against NUST LMS on your behalf and returns a gateway JWT. The LMS session (cookie + sesskey) is created and held server-side; use the returned token as `Authorization: Bearer <token>` for every other operation.
    headers:
      Content-Type:
        required: true
        displayName: Content-Type
        enum:
        - application/json
    body:
      application/json:
        schema: |
          {
            "id": "LoginRequest",
            "title": "LoginRequest",
            "description": "NUST LMS credentials.",
            "type": "object",
            "properties": {
              "email": {
                "description": "NUST LMS username or email.",
                "example": "john.doe@student.nust.edu.pk",
                "type": "string"
              },
              "password": {
                "description": "NUST LMS password.",
                "type": "string",
                "format": "password"
              }
            },
            "required": [
              "email",
              "password"
            ]
          }
        example: ''
    responses:
      '200':
        description: Authentication succeeded; bearer token issued.
        body:
          application/json:
            schema: |
              {
                "id": "TokenResponse",
                "title": "TokenResponse",
                "description": "Bearer token issued by the gateway after a successful login.",
                "type": "object",
                "properties": {
                  "access_token": {
                    "description": "JWT to send as `Authorization: Bearer <token>` on subsequent requests.",
                    "type": "string"
                  },
                  "token_type": {
                    "example": "bearer",
                    "type": "string"
                  }
                },
                "required": [
                  "access_token",
                  "token_type"
                ]
              }
      '401':
        description: Invalid LMS credentials.
        body:
          application/json:
            schema: |
              {
                "id": "AuthLogin401Error1",
                "title": "AuthLogin401Error1",
                "type": "object",
                "properties": {
                  "detail": {
                    "example": "Invalid LMS credentials.",
                    "type": "string"
                  }
                }
              }
/service:
  /core_course_get_recent_courses:
    post:
      description: >
        Returns the courses the authenticated user has accessed most recently, ordered by last access time.

        Moodle method: `core_course_get_recent_courses`
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      body:
        application/json:
          schema: |
            {
              "id": "GetRecentCoursesRequest",
              "title": "GetRecentCoursesRequest",
              "description": "Parameters for the recent courses request.",
              "type": "object",
              "properties": {
                "limit": {
                  "description": "Maximum number of courses to return.",
                  "example": 10,
                  "type": "integer",
                  "format": "int32"
                }
              },
              "required": [
                "limit"
              ]
            }
          example: ''
      responses:
        '200':
          description: List of recently accessed courses ordered by last access.
          body:
            application/json:
              schema: |
                {
                  "description": "Recently accessed courses ordered by last access time.",
                  "type": "array",
                  "items": {
                    "id": "RecentCourse",
                    "title": "RecentCourse",
                    "description": "A recently accessed course, extending Course with the last-access timestamp.",
                    "type": "object",
                    "properties": {
                      "id": {
                        "description": "Unique course identifier.",
                        "example": 49900,
                        "type": "integer",
                        "format": "int32"
                      },
                      "fullname": {
                        "description": "Full display name of the course.",
                        "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                        "type": "string"
                      },
                      "shortname": {
                        "description": "Short course code or abbreviated name.",
                        "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
                        "type": "string"
                      },
                      "idnumber": {
                        "description": "Institution-assigned course ID number; empty string if not set.",
                        "type": "string"
                      },
                      "summary": {
                        "description": "HTML summary of the course.",
                        "type": "string"
                      },
                      "summaryformat": {
                        "description": "Format of the summary field (1 = HTML).",
                        "example": 1,
                        "type": "integer",
                        "format": "int32"
                      },
                      "startdate": {
                        "description": "Course start date as Unix timestamp.",
                        "example": 1706468400,
                        "type": "integer",
                        "format": "int32"
                      },
                      "enddate": {
                        "description": "Course end date as Unix timestamp. 0 means no end date.",
                        "example": 1717362000,
                        "type": "integer",
                        "format": "int32"
                      },
                      "visible": {
                        "description": "Whether the course is visible to enrolled students.",
                        "example": true,
                        "type": "boolean"
                      },
                      "fullnamedisplay": {
                        "description": "Display name of the course (may differ from fullname for context).",
                        "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                        "type": "string"
                      },
                      "viewurl": {
                        "description": "URL to the course page on the LMS portal.",
                        "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
                        "type": "string"
                      },
                      "progress": {
                        "description": "Student's completion progress as a percentage.",
                        "example": 21,
                        "type": "integer",
                        "minimum": 0.0,
                        "maximum": 100.0,
                        "format": "int32"
                      },
                      "hasprogress": {
                        "description": "Whether completion tracking is enabled for this course.",
                        "example": true,
                        "type": "boolean"
                      },
                      "isfavourite": {
                        "description": "Whether the user has marked this course as a favourite.",
                        "example": false,
                        "type": "boolean"
                      },
                      "hidden": {
                        "description": "Whether the user has hidden this course from their dashboard.",
                        "example": false,
                        "type": "boolean"
                      },
                      "showshortname": {
                        "description": "Whether the short name is displayed alongside the full name.",
                        "example": false,
                        "type": "boolean"
                      },
                      "coursecategory": {
                        "description": "Name of the category this course belongs to.",
                        "example": "2nd Semester (SP-2024)",
                        "type": "string"
                      },
                      "timeaccess": {
                        "description": "Unix timestamp of the user's most recent access to this course.",
                        "example": 1781632422,
                        "type": "integer",
                        "format": "int32"
                      }
                    },
                    "required": [
                      "id",
                      "fullname",
                      "shortname",
                      "idnumber",
                      "summary",
                      "summaryformat",
                      "startdate",
                      "enddate",
                      "visible",
                      "fullnamedisplay",
                      "viewurl",
                      "progress",
                      "hasprogress",
                      "isfavourite",
                      "hidden",
                      "showshortname",
                      "coursecategory",
                      "timeaccess"
                    ]
                  }
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /core_course_get_enrolled_courses_by_timeline_classification:
    post:
      description: >
        Returns all courses the user is enrolled in, filtered by timeline classification and sorted by a chosen field. Supports pagination via offset.

        Moodle method: `core_course_get_enrolled_courses_by_timeline_classification`
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      body:
        application/json:
          schema: |
            {
              "id": "GetEnrolledCoursesByTimelineRequest",
              "title": "GetEnrolledCoursesByTimelineRequest",
              "description": "Parameters for the enrolled courses timeline request.",
              "type": "object",
              "properties": {
                "offset": {
                  "description": "Zero-based pagination offset.",
                  "example": 0,
                  "type": "integer",
                  "format": "int32"
                },
                "limit": {
                  "description": "Maximum number of courses to return.",
                  "example": 50,
                  "type": "integer",
                  "format": "int32"
                },
                "classification": {
                  "title": "CourseTimelineClassification",
                  "description": "Timeline classification filter for enrolled courses.",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "all",
                    "inprogress",
                    "past",
                    "future",
                    "favourite",
                    "hidden",
                    "allincludinghidden"
                  ]
                },
                "sort": {
                  "title": "CourseTimelineSortField",
                  "description": "Field used to sort enrolled course results.",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "fullname",
                    "shortname",
                    "id",
                    "idnumber",
                    "timeaccess"
                  ]
                }
              },
              "required": [
                "offset",
                "limit",
                "classification",
                "sort"
              ]
            }
          example: ''
      responses:
        '200':
          description: Paginated list of enrolled courses.
          body:
            application/json:
              schema: |
                {
                  "id": "EnrolledCoursesResponse",
                  "title": "EnrolledCoursesResponse",
                  "description": "Paginated enrolled-courses response.",
                  "type": "object",
                  "properties": {
                    "courses": {
                      "description": "List of enrolled courses for the current page.",
                      "type": "array",
                      "items": {
                        "id": "Course",
                        "title": "Course",
                        "description": "An enrolled course.",
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "Unique course identifier.",
                            "example": 49900,
                            "type": "integer",
                            "format": "int32"
                          },
                          "fullname": {
                            "description": "Full display name of the course.",
                            "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                            "type": "string"
                          },
                          "shortname": {
                            "description": "Short course code or abbreviated name.",
                            "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
                            "type": "string"
                          },
                          "idnumber": {
                            "description": "Institution-assigned course ID number; empty string if not set.",
                            "type": "string"
                          },
                          "summary": {
                            "description": "HTML summary of the course.",
                            "type": "string"
                          },
                          "summaryformat": {
                            "description": "Format of the summary field (1 = HTML).",
                            "example": 1,
                            "type": "integer",
                            "format": "int32"
                          },
                          "startdate": {
                            "description": "Course start date as Unix timestamp.",
                            "example": 1706468400,
                            "type": "integer",
                            "format": "int32"
                          },
                          "enddate": {
                            "description": "Course end date as Unix timestamp. 0 means no end date.",
                            "example": 1717362000,
                            "type": "integer",
                            "format": "int32"
                          },
                          "visible": {
                            "description": "Whether the course is visible to enrolled students.",
                            "example": true,
                            "type": "boolean"
                          },
                          "fullnamedisplay": {
                            "description": "Display name of the course (may differ from fullname for context).",
                            "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                            "type": "string"
                          },
                          "viewurl": {
                            "description": "URL to the course page on the LMS portal.",
                            "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
                            "type": "string"
                          },
                          "progress": {
                            "description": "Student's completion progress as a percentage.",
                            "example": 21,
                            "type": "integer",
                            "minimum": 0.0,
                            "maximum": 100.0,
                            "format": "int32"
                          },
                          "hasprogress": {
                            "description": "Whether completion tracking is enabled for this course.",
                            "example": true,
                            "type": "boolean"
                          },
                          "isfavourite": {
                            "description": "Whether the user has marked this course as a favourite.",
                            "example": false,
                            "type": "boolean"
                          },
                          "hidden": {
                            "description": "Whether the user has hidden this course from their dashboard.",
                            "example": false,
                            "type": "boolean"
                          },
                          "showshortname": {
                            "description": "Whether the short name is displayed alongside the full name.",
                            "example": false,
                            "type": "boolean"
                          },
                          "coursecategory": {
                            "description": "Name of the category this course belongs to.",
                            "example": "2nd Semester (SP-2024)",
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "fullname",
                          "shortname",
                          "idnumber",
                          "summary",
                          "summaryformat",
                          "startdate",
                          "enddate",
                          "visible",
                          "fullnamedisplay",
                          "viewurl",
                          "progress",
                          "hasprogress",
                          "isfavourite",
                          "hidden",
                          "showshortname",
                          "coursecategory"
                        ]
                      }
                    },
                    "nextoffset": {
                      "description": "Offset to pass on the next page request; -1 when no further pages exist.",
                      "example": 29,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "courses",
                    "nextoffset"
                  ]
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /core_calendar_get_action_events_by_timesort:
    post:
      description: >
        Returns action events across all enrolled courses, ordered by their sort timestamp. Use `timesortfrom` to filter to upcoming events only.

        Moodle method: `core_calendar_get_action_events_by_timesort`
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      body:
        application/json:
          schema: |
            {
              "id": "GetCalendarEventsByTimesortRequest",
              "title": "GetCalendarEventsByTimesortRequest",
              "description": "Parameters for the time-sorted calendar events request.",
              "type": "object",
              "properties": {
                "limitnum": {
                  "description": "Maximum number of events to return.",
                  "example": 20,
                  "type": "integer",
                  "format": "int32"
                },
                "timesortfrom": {
                  "description": "Only return events with timesort >= this Unix timestamp. Pass 0 for no lower bound.",
                  "example": 0,
                  "type": "integer",
                  "format": "int32"
                },
                "timesortto": {
                  "description": "Only return events with timesort <= this Unix timestamp. Optional.",
                  "type": "integer",
                  "format": "int32"
                },
                "aftereventid": {
                  "description": "Return events whose ID is greater than this value (cursor pagination). Optional.",
                  "type": "integer",
                  "format": "int32"
                }
              },
              "required": [
                "limitnum",
                "timesortfrom"
              ]
            }
          example: ''
      responses:
        '200':
          description: Calendar events sorted by timesort.
          body:
            application/json:
              schema: |
                {
                  "id": "CalendarEventsResponse",
                  "title": "CalendarEventsResponse",
                  "description": "A list of calendar events with pagination boundary IDs.",
                  "type": "object",
                  "properties": {
                    "events": {
                      "description": "List of calendar action events for the current result set.",
                      "type": "array",
                      "items": {
                        "id": "CalendarEvent",
                        "title": "CalendarEvent",
                        "description": "A calendar action event tied to a course activity (e.g., an assignment deadline).",
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "Unique calendar event identifier.",
                            "example": 149885,
                            "type": "integer",
                            "format": "int32"
                          },
                          "name": {
                            "description": "Display name of the calendar event.",
                            "example": "Lab 1 BSCS 13C is due",
                            "type": "string"
                          },
                          "description": {
                            "description": "HTML description body of the event.",
                            "example": "<p dir=\"ltr\">Lab 1 BSCS 13C<br /></p>",
                            "type": "string"
                          },
                          "descriptionformat": {
                            "description": "Text format of the description (1 = HTML).",
                            "example": 1,
                            "type": "integer",
                            "format": "int32"
                          },
                          "location": {
                            "description": "Physical or virtual location of the event; empty string if not specified.",
                            "type": "string"
                          },
                          "component": {
                            "description": "Moodle component that created the event (e.g., 'mod_assign').",
                            "example": "mod_assign",
                            "type": "string"
                          },
                          "modulename": {
                            "description": "Short name of the Moodle activity module (e.g., 'assign').",
                            "example": "assign",
                            "type": "string"
                          },
                          "instance": {
                            "description": "The course module instance ID.",
                            "example": 999404,
                            "type": "integer",
                            "format": "int32"
                          },
                          "eventtype": {
                            "description": "Type of the event (e.g., 'due', 'open', 'close').",
                            "example": "due",
                            "type": "string"
                          },
                          "timestart": {
                            "description": "Event start time as Unix timestamp.",
                            "example": 1706900340,
                            "type": "integer",
                            "format": "int32"
                          },
                          "timeduration": {
                            "description": "Duration in seconds; 0 for point-in-time events.",
                            "example": 0,
                            "type": "integer",
                            "format": "int32"
                          },
                          "timesort": {
                            "description": "Sort timestamp used for ordering events.",
                            "example": 1706900340,
                            "type": "integer",
                            "format": "int32"
                          },
                          "visible": {
                            "description": "Visibility flag for a calendar event. 1 means the event is visible; 0 means it is hidden.",
                            "type": "integer",
                            "format": "int32"
                          },
                          "timemodified": {
                            "description": "Last modification time as Unix timestamp.",
                            "example": 1779088440,
                            "type": "integer",
                            "format": "int32"
                          },
                          "icon": {
                            "id": "EventIcon",
                            "title": "EventIcon",
                            "description": "Icon metadata for a calendar event.",
                            "type": "object",
                            "properties": {
                              "key": {
                                "description": "Icon key name used to locate the icon asset.",
                                "example": "icon",
                                "type": "string"
                              },
                              "component": {
                                "description": "Moodle component that owns the icon (e.g., 'assign').",
                                "example": "assign",
                                "type": "string"
                              },
                              "alttext": {
                                "description": "Accessible alt text for the icon image.",
                                "example": "Activity event",
                                "type": "string"
                              }
                            },
                            "required": [
                              "key",
                              "component",
                              "alttext"
                            ]
                          },
                          "course": {
                            "id": "Course",
                            "title": "Course",
                            "description": "An enrolled course.",
                            "type": "object",
                            "properties": {
                              "id": {
                                "description": "Unique course identifier.",
                                "example": 49900,
                                "type": "integer",
                                "format": "int32"
                              },
                              "fullname": {
                                "description": "Full display name of the course.",
                                "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                                "type": "string"
                              },
                              "shortname": {
                                "description": "Short course code or abbreviated name.",
                                "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
                                "type": "string"
                              },
                              "idnumber": {
                                "description": "Institution-assigned course ID number; empty string if not set.",
                                "type": "string"
                              },
                              "summary": {
                                "description": "HTML summary of the course.",
                                "type": "string"
                              },
                              "summaryformat": {
                                "description": "Format of the summary field (1 = HTML).",
                                "example": 1,
                                "type": "integer",
                                "format": "int32"
                              },
                              "startdate": {
                                "description": "Course start date as Unix timestamp.",
                                "example": 1706468400,
                                "type": "integer",
                                "format": "int32"
                              },
                              "enddate": {
                                "description": "Course end date as Unix timestamp. 0 means no end date.",
                                "example": 1717362000,
                                "type": "integer",
                                "format": "int32"
                              },
                              "visible": {
                                "description": "Whether the course is visible to enrolled students.",
                                "example": true,
                                "type": "boolean"
                              },
                              "fullnamedisplay": {
                                "description": "Display name of the course (may differ from fullname for context).",
                                "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                                "type": "string"
                              },
                              "viewurl": {
                                "description": "URL to the course page on the LMS portal.",
                                "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
                                "type": "string"
                              },
                              "progress": {
                                "description": "Student's completion progress as a percentage.",
                                "example": 21,
                                "type": "integer",
                                "minimum": 0.0,
                                "maximum": 100.0,
                                "format": "int32"
                              },
                              "hasprogress": {
                                "description": "Whether completion tracking is enabled for this course.",
                                "example": true,
                                "type": "boolean"
                              },
                              "isfavourite": {
                                "description": "Whether the user has marked this course as a favourite.",
                                "example": false,
                                "type": "boolean"
                              },
                              "hidden": {
                                "description": "Whether the user has hidden this course from their dashboard.",
                                "example": false,
                                "type": "boolean"
                              },
                              "showshortname": {
                                "description": "Whether the short name is displayed alongside the full name.",
                                "example": false,
                                "type": "boolean"
                              },
                              "coursecategory": {
                                "description": "Name of the category this course belongs to.",
                                "example": "2nd Semester (SP-2024)",
                                "type": "string"
                              }
                            },
                            "required": [
                              "id",
                              "fullname",
                              "shortname",
                              "idnumber",
                              "summary",
                              "summaryformat",
                              "startdate",
                              "enddate",
                              "visible",
                              "fullnamedisplay",
                              "viewurl",
                              "progress",
                              "hasprogress",
                              "isfavourite",
                              "hidden",
                              "showshortname",
                              "coursecategory"
                            ]
                          },
                          "subscription": {
                            "id": "EventSubscription",
                            "title": "EventSubscription",
                            "description": "Subscription display settings for a calendar event.",
                            "type": "object",
                            "properties": {
                              "displayeventsource": {
                                "description": "Whether to display the event source label on the calendar.",
                                "example": false,
                                "type": "boolean"
                              }
                            },
                            "required": [
                              "displayeventsource"
                            ]
                          },
                          "canedit": {
                            "description": "Whether the current user can edit this event.",
                            "example": false,
                            "type": "boolean"
                          },
                          "candelete": {
                            "description": "Whether the current user can delete this event.",
                            "example": false,
                            "type": "boolean"
                          },
                          "deleteurl": {
                            "description": "URL to delete this calendar event.",
                            "example": "https://lms.nust.edu.pk/portal/calendar/delete.php?id=149885&course=49900",
                            "type": "string"
                          },
                          "editurl": {
                            "description": "URL to edit the underlying course module associated with this event.",
                            "example": "https://lms.nust.edu.pk/portal/course/mod.php?update=999404&return=1&sesskey=XXXX",
                            "type": "string"
                          },
                          "viewurl": {
                            "description": "URL to view this event on the calendar.",
                            "example": "https://lms.nust.edu.pk/portal/calendar/view.php?view=day&course=49900&time=1706900340",
                            "type": "string"
                          },
                          "formattedtime": {
                            "description": "HTML-formatted human-readable event time string.",
                            "example": "<span class=\"dimmed_text\">Friday, 2 February, 11:59 PM</span>",
                            "type": "string"
                          },
                          "isactionevent": {
                            "description": "Whether this is an action event requiring user interaction.",
                            "example": true,
                            "type": "boolean"
                          },
                          "iscourseevent": {
                            "description": "Whether this event is associated with a specific course.",
                            "example": false,
                            "type": "boolean"
                          },
                          "iscategoryevent": {
                            "description": "Whether this event is associated with a course category.",
                            "example": false,
                            "type": "boolean"
                          },
                          "normalisedeventtype": {
                            "description": "Normalised event type identifier used for display grouping.",
                            "example": "course",
                            "type": "string"
                          },
                          "normalisedeventtypetext": {
                            "description": "Human-readable label for the normalised event type.",
                            "example": "Course event",
                            "type": "string"
                          },
                          "url": {
                            "description": "Direct URL to the course activity associated with this event.",
                            "example": "https://lms.nust.edu.pk/portal/mod/assign/view.php?id=999404",
                            "type": "string"
                          },
                          "categoryid": {
                            "description": "Course category ID; null if not a category event.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "groupid": {
                            "description": "Group ID if the event is group-specific; null otherwise.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "userid": {
                            "description": "User ID if the event is user-specific; null otherwise.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "repeatid": {
                            "description": "ID of the repeat group for recurring events; null if not recurring.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "eventcount": {
                            "description": "Total number of events in the repeat group; null if not applicable.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "groupname": {
                            "description": "Name of the group for group-specific events; null otherwise.",
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "action": {
                            "id": "EventAction",
                            "title": "EventAction",
                            "description": "Primary action button metadata for a calendar event.",
                            "type": "object",
                            "properties": {
                              "name": {
                                "description": "Display label for the primary action button.",
                                "example": "Add submission",
                                "type": "string"
                              },
                              "url": {
                                "description": "URL the user should navigate to in order to perform the action.",
                                "example": "https://lms.nust.edu.pk/portal/mod/assign/view.php?id=999404&action=editsubmission",
                                "type": "string"
                              },
                              "itemcount": {
                                "description": "Number of items associated with this action.",
                                "example": 1,
                                "type": "integer",
                                "format": "int32"
                              },
                              "actionable": {
                                "description": "Whether the action can currently be taken by the user.",
                                "example": true,
                                "type": "boolean"
                              },
                              "showitemcount": {
                                "description": "Whether to display the item count alongside the action label.",
                                "example": false,
                                "type": "boolean"
                              }
                            },
                            "required": [
                              "name",
                              "url",
                              "itemcount",
                              "actionable",
                              "showitemcount"
                            ]
                          }
                        },
                        "required": [
                          "id",
                          "name",
                          "description",
                          "descriptionformat",
                          "location",
                          "component",
                          "modulename",
                          "instance",
                          "eventtype",
                          "timestart",
                          "timeduration",
                          "timesort",
                          "visible",
                          "timemodified",
                          "icon",
                          "course",
                          "subscription",
                          "canedit",
                          "candelete",
                          "deleteurl",
                          "editurl",
                          "viewurl",
                          "formattedtime",
                          "isactionevent",
                          "iscourseevent",
                          "iscategoryevent",
                          "normalisedeventtype",
                          "normalisedeventtypetext",
                          "url"
                        ]
                      }
                    },
                    "firstid": {
                      "description": "Event ID of the first item in the result set.",
                      "example": 149885,
                      "type": "integer",
                      "format": "int32"
                    },
                    "lastid": {
                      "description": "Event ID of the last item in the result set.",
                      "example": 151886,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "events",
                    "firstid",
                    "lastid"
                  ]
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /core_calendar_get_action_events_by_course:
    post:
      description: >
        Returns all action events (assignments, quizzes, etc.) for a single course.

        Moodle method: `core_calendar_get_action_events_by_course`
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      body:
        application/json:
          schema: |
            {
              "id": "GetCalendarEventsByCourseRequest",
              "title": "GetCalendarEventsByCourseRequest",
              "description": "Parameters for the course-specific calendar events request.",
              "type": "object",
              "properties": {
                "courseid": {
                  "description": "ID of the course to fetch events for.",
                  "example": 49906,
                  "type": "integer",
                  "format": "int32"
                },
                "timesortfrom": {
                  "description": "Only return events with timesort >= this Unix timestamp. Optional.",
                  "type": "integer",
                  "format": "int32"
                },
                "timesortto": {
                  "description": "Only return events with timesort <= this Unix timestamp. Optional.",
                  "type": "integer",
                  "format": "int32"
                },
                "aftereventid": {
                  "description": "Cursor-based pagination — return events after this event ID. Optional.",
                  "type": "integer",
                  "format": "int32"
                },
                "limitnum": {
                  "description": "Maximum number of events to return. Optional.",
                  "type": "integer",
                  "format": "int32"
                }
              },
              "required": [
                "courseid"
              ]
            }
          example: ''
      responses:
        '200':
          description: Calendar events for the specified course.
          body:
            application/json:
              schema: |
                {
                  "id": "CalendarEventsResponse",
                  "title": "CalendarEventsResponse",
                  "description": "A list of calendar events with pagination boundary IDs.",
                  "type": "object",
                  "properties": {
                    "events": {
                      "description": "List of calendar action events for the current result set.",
                      "type": "array",
                      "items": {
                        "id": "CalendarEvent",
                        "title": "CalendarEvent",
                        "description": "A calendar action event tied to a course activity (e.g., an assignment deadline).",
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "Unique calendar event identifier.",
                            "example": 149885,
                            "type": "integer",
                            "format": "int32"
                          },
                          "name": {
                            "description": "Display name of the calendar event.",
                            "example": "Lab 1 BSCS 13C is due",
                            "type": "string"
                          },
                          "description": {
                            "description": "HTML description body of the event.",
                            "example": "<p dir=\"ltr\">Lab 1 BSCS 13C<br /></p>",
                            "type": "string"
                          },
                          "descriptionformat": {
                            "description": "Text format of the description (1 = HTML).",
                            "example": 1,
                            "type": "integer",
                            "format": "int32"
                          },
                          "location": {
                            "description": "Physical or virtual location of the event; empty string if not specified.",
                            "type": "string"
                          },
                          "component": {
                            "description": "Moodle component that created the event (e.g., 'mod_assign').",
                            "example": "mod_assign",
                            "type": "string"
                          },
                          "modulename": {
                            "description": "Short name of the Moodle activity module (e.g., 'assign').",
                            "example": "assign",
                            "type": "string"
                          },
                          "instance": {
                            "description": "The course module instance ID.",
                            "example": 999404,
                            "type": "integer",
                            "format": "int32"
                          },
                          "eventtype": {
                            "description": "Type of the event (e.g., 'due', 'open', 'close').",
                            "example": "due",
                            "type": "string"
                          },
                          "timestart": {
                            "description": "Event start time as Unix timestamp.",
                            "example": 1706900340,
                            "type": "integer",
                            "format": "int32"
                          },
                          "timeduration": {
                            "description": "Duration in seconds; 0 for point-in-time events.",
                            "example": 0,
                            "type": "integer",
                            "format": "int32"
                          },
                          "timesort": {
                            "description": "Sort timestamp used for ordering events.",
                            "example": 1706900340,
                            "type": "integer",
                            "format": "int32"
                          },
                          "visible": {
                            "description": "Visibility flag for a calendar event. 1 means the event is visible; 0 means it is hidden.",
                            "type": "integer",
                            "format": "int32"
                          },
                          "timemodified": {
                            "description": "Last modification time as Unix timestamp.",
                            "example": 1779088440,
                            "type": "integer",
                            "format": "int32"
                          },
                          "icon": {
                            "id": "EventIcon",
                            "title": "EventIcon",
                            "description": "Icon metadata for a calendar event.",
                            "type": "object",
                            "properties": {
                              "key": {
                                "description": "Icon key name used to locate the icon asset.",
                                "example": "icon",
                                "type": "string"
                              },
                              "component": {
                                "description": "Moodle component that owns the icon (e.g., 'assign').",
                                "example": "assign",
                                "type": "string"
                              },
                              "alttext": {
                                "description": "Accessible alt text for the icon image.",
                                "example": "Activity event",
                                "type": "string"
                              }
                            },
                            "required": [
                              "key",
                              "component",
                              "alttext"
                            ]
                          },
                          "course": {
                            "id": "Course",
                            "title": "Course",
                            "description": "An enrolled course.",
                            "type": "object",
                            "properties": {
                              "id": {
                                "description": "Unique course identifier.",
                                "example": 49900,
                                "type": "integer",
                                "format": "int32"
                              },
                              "fullname": {
                                "description": "Full display name of the course.",
                                "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                                "type": "string"
                              },
                              "shortname": {
                                "description": "Short course code or abbreviated name.",
                                "example": "CS-212-Sp'24 BSCS-13 2K23 ABC",
                                "type": "string"
                              },
                              "idnumber": {
                                "description": "Institution-assigned course ID number; empty string if not set.",
                                "type": "string"
                              },
                              "summary": {
                                "description": "HTML summary of the course.",
                                "type": "string"
                              },
                              "summaryformat": {
                                "description": "Format of the summary field (1 = HTML).",
                                "example": 1,
                                "type": "integer",
                                "format": "int32"
                              },
                              "startdate": {
                                "description": "Course start date as Unix timestamp.",
                                "example": 1706468400,
                                "type": "integer",
                                "format": "int32"
                              },
                              "enddate": {
                                "description": "Course end date as Unix timestamp. 0 means no end date.",
                                "example": 1717362000,
                                "type": "integer",
                                "format": "int32"
                              },
                              "visible": {
                                "description": "Whether the course is visible to enrolled students.",
                                "example": true,
                                "type": "boolean"
                              },
                              "fullnamedisplay": {
                                "description": "Display name of the course (may differ from fullname for context).",
                                "example": "CS-212 Object Oriented Programming BSCS-13 2K23 ABC",
                                "type": "string"
                              },
                              "viewurl": {
                                "description": "URL to the course page on the LMS portal.",
                                "example": "https://lms.nust.edu.pk/portal/course/view.php?id=49900",
                                "type": "string"
                              },
                              "progress": {
                                "description": "Student's completion progress as a percentage.",
                                "example": 21,
                                "type": "integer",
                                "minimum": 0.0,
                                "maximum": 100.0,
                                "format": "int32"
                              },
                              "hasprogress": {
                                "description": "Whether completion tracking is enabled for this course.",
                                "example": true,
                                "type": "boolean"
                              },
                              "isfavourite": {
                                "description": "Whether the user has marked this course as a favourite.",
                                "example": false,
                                "type": "boolean"
                              },
                              "hidden": {
                                "description": "Whether the user has hidden this course from their dashboard.",
                                "example": false,
                                "type": "boolean"
                              },
                              "showshortname": {
                                "description": "Whether the short name is displayed alongside the full name.",
                                "example": false,
                                "type": "boolean"
                              },
                              "coursecategory": {
                                "description": "Name of the category this course belongs to.",
                                "example": "2nd Semester (SP-2024)",
                                "type": "string"
                              }
                            },
                            "required": [
                              "id",
                              "fullname",
                              "shortname",
                              "idnumber",
                              "summary",
                              "summaryformat",
                              "startdate",
                              "enddate",
                              "visible",
                              "fullnamedisplay",
                              "viewurl",
                              "progress",
                              "hasprogress",
                              "isfavourite",
                              "hidden",
                              "showshortname",
                              "coursecategory"
                            ]
                          },
                          "subscription": {
                            "id": "EventSubscription",
                            "title": "EventSubscription",
                            "description": "Subscription display settings for a calendar event.",
                            "type": "object",
                            "properties": {
                              "displayeventsource": {
                                "description": "Whether to display the event source label on the calendar.",
                                "example": false,
                                "type": "boolean"
                              }
                            },
                            "required": [
                              "displayeventsource"
                            ]
                          },
                          "canedit": {
                            "description": "Whether the current user can edit this event.",
                            "example": false,
                            "type": "boolean"
                          },
                          "candelete": {
                            "description": "Whether the current user can delete this event.",
                            "example": false,
                            "type": "boolean"
                          },
                          "deleteurl": {
                            "description": "URL to delete this calendar event.",
                            "example": "https://lms.nust.edu.pk/portal/calendar/delete.php?id=149885&course=49900",
                            "type": "string"
                          },
                          "editurl": {
                            "description": "URL to edit the underlying course module associated with this event.",
                            "example": "https://lms.nust.edu.pk/portal/course/mod.php?update=999404&return=1&sesskey=XXXX",
                            "type": "string"
                          },
                          "viewurl": {
                            "description": "URL to view this event on the calendar.",
                            "example": "https://lms.nust.edu.pk/portal/calendar/view.php?view=day&course=49900&time=1706900340",
                            "type": "string"
                          },
                          "formattedtime": {
                            "description": "HTML-formatted human-readable event time string.",
                            "example": "<span class=\"dimmed_text\">Friday, 2 February, 11:59 PM</span>",
                            "type": "string"
                          },
                          "isactionevent": {
                            "description": "Whether this is an action event requiring user interaction.",
                            "example": true,
                            "type": "boolean"
                          },
                          "iscourseevent": {
                            "description": "Whether this event is associated with a specific course.",
                            "example": false,
                            "type": "boolean"
                          },
                          "iscategoryevent": {
                            "description": "Whether this event is associated with a course category.",
                            "example": false,
                            "type": "boolean"
                          },
                          "normalisedeventtype": {
                            "description": "Normalised event type identifier used for display grouping.",
                            "example": "course",
                            "type": "string"
                          },
                          "normalisedeventtypetext": {
                            "description": "Human-readable label for the normalised event type.",
                            "example": "Course event",
                            "type": "string"
                          },
                          "url": {
                            "description": "Direct URL to the course activity associated with this event.",
                            "example": "https://lms.nust.edu.pk/portal/mod/assign/view.php?id=999404",
                            "type": "string"
                          },
                          "categoryid": {
                            "description": "Course category ID; null if not a category event.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "groupid": {
                            "description": "Group ID if the event is group-specific; null otherwise.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "userid": {
                            "description": "User ID if the event is user-specific; null otherwise.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "repeatid": {
                            "description": "ID of the repeat group for recurring events; null if not recurring.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "eventcount": {
                            "description": "Total number of events in the repeat group; null if not applicable.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          },
                          "groupname": {
                            "description": "Name of the group for group-specific events; null otherwise.",
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "action": {
                            "id": "EventAction",
                            "title": "EventAction",
                            "description": "Primary action button metadata for a calendar event.",
                            "type": "object",
                            "properties": {
                              "name": {
                                "description": "Display label for the primary action button.",
                                "example": "Add submission",
                                "type": "string"
                              },
                              "url": {
                                "description": "URL the user should navigate to in order to perform the action.",
                                "example": "https://lms.nust.edu.pk/portal/mod/assign/view.php?id=999404&action=editsubmission",
                                "type": "string"
                              },
                              "itemcount": {
                                "description": "Number of items associated with this action.",
                                "example": 1,
                                "type": "integer",
                                "format": "int32"
                              },
                              "actionable": {
                                "description": "Whether the action can currently be taken by the user.",
                                "example": true,
                                "type": "boolean"
                              },
                              "showitemcount": {
                                "description": "Whether to display the item count alongside the action label.",
                                "example": false,
                                "type": "boolean"
                              }
                            },
                            "required": [
                              "name",
                              "url",
                              "itemcount",
                              "actionable",
                              "showitemcount"
                            ]
                          }
                        },
                        "required": [
                          "id",
                          "name",
                          "description",
                          "descriptionformat",
                          "location",
                          "component",
                          "modulename",
                          "instance",
                          "eventtype",
                          "timestart",
                          "timeduration",
                          "timesort",
                          "visible",
                          "timemodified",
                          "icon",
                          "course",
                          "subscription",
                          "canedit",
                          "candelete",
                          "deleteurl",
                          "editurl",
                          "viewurl",
                          "formattedtime",
                          "isactionevent",
                          "iscourseevent",
                          "iscategoryevent",
                          "normalisedeventtype",
                          "normalisedeventtypetext",
                          "url"
                        ]
                      }
                    },
                    "firstid": {
                      "description": "Event ID of the first item in the result set.",
                      "example": 149885,
                      "type": "integer",
                      "format": "int32"
                    },
                    "lastid": {
                      "description": "Event ID of the last item in the result set.",
                      "example": 151886,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "events",
                    "firstid",
                    "lastid"
                  ]
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /core_user_get_users_by_field:
    post:
      description: >
        Retrieves one or more user profiles by matching a specific profile field. Commonly used to look up the authenticated user's own profile by their ID.

        Moodle method: `core_user_get_users_by_field`
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      body:
        application/json:
          schema: |
            {
              "id": "GetUsersByFieldRequest",
              "title": "GetUsersByFieldRequest",
              "description": "Parameters specifying the profile field and values to match.",
              "type": "object",
              "properties": {
                "field": {
                  "title": "UserProfileField",
                  "description": "User profile field to match against when searching for users.",
                  "type": "string",
                  "additionalProperties": false,
                  "enum": [
                    "id",
                    "idnumber",
                    "username",
                    "email"
                  ]
                },
                "values": {
                  "description": "List of field values to look up. All values must be provided as strings even when the field is numeric (e.g., \"162154\" for an integer ID).",
                  "example": [
                    "162154"
                  ],
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "field",
                "values"
              ]
            }
          example: ''
      responses:
        '200':
          description: List of matching user profiles.
          body:
            application/json:
              schema: |
                {
                  "description": "User profiles matching the specified field value.",
                  "type": "array",
                  "items": {
                    "id": "UserProfile",
                    "title": "UserProfile",
                    "description": "Complete user profile.",
                    "type": "object",
                    "properties": {
                      "id": {
                        "description": "Unique numeric user identifier.",
                        "example": 162154,
                        "type": "integer",
                        "format": "int32"
                      },
                      "username": {
                        "description": "Login username for the user.",
                        "example": "hhameed.bscs23seecs",
                        "type": "string"
                      },
                      "fullname": {
                        "description": "Full display name of the user.",
                        "example": "Hasaan Hameed",
                        "type": "string"
                      },
                      "email": {
                        "description": "Email address of the user.",
                        "example": "hhameed.bscs23seecs@seecs.edu.pk",
                        "type": "string"
                      },
                      "department": {
                        "description": "Department the user belongs to within the institution.",
                        "example": "FoC",
                        "type": "string"
                      },
                      "institution": {
                        "description": "Name of the institution the user is affiliated with.",
                        "example": "SEECS",
                        "type": "string"
                      },
                      "idnumber": {
                        "description": "Institution-assigned student or staff ID number.",
                        "example": "00000454987",
                        "type": "string"
                      },
                      "auth": {
                        "description": "Authentication method used by the user (e.g., 'ldap', 'manual').",
                        "example": "ldap",
                        "type": "string"
                      },
                      "confirmed": {
                        "description": "Whether the user's account has been confirmed.",
                        "example": true,
                        "type": "boolean"
                      },
                      "lang": {
                        "description": "Preferred interface language code (e.g., 'en').",
                        "example": "en",
                        "type": "string"
                      },
                      "theme": {
                        "description": "Preferred LMS theme; empty string means use the site default.",
                        "type": "string"
                      },
                      "timezone": {
                        "description": "Timezone identifier. \"99\" means use the server default.",
                        "example": "99",
                        "type": "string"
                      },
                      "mailformat": {
                        "description": "Email format preference (1 = HTML).",
                        "example": 1,
                        "type": "integer",
                        "format": "int32"
                      },
                      "profileimageurlsmall": {
                        "description": "URL to the user's small profile image (thumbnail).",
                        "example": "https://lms.nust.edu.pk/portal/pluginfile.php/1583361/user/icon/moove/f2?rev=14452894",
                        "type": "string"
                      },
                      "profileimageurl": {
                        "description": "URL to the user's full-size profile image.",
                        "example": "https://lms.nust.edu.pk/portal/pluginfile.php/1583361/user/icon/moove/f1?rev=14452894",
                        "type": "string"
                      },
                      "customfields": {
                        "description": "List of custom profile field values for the user.",
                        "type": "array",
                        "items": {
                          "id": "CustomField",
                          "title": "CustomField",
                          "description": "A custom profile field value attached to a user.",
                          "type": "object",
                          "properties": {
                            "type": {
                              "description": "Data type of the custom field (e.g., 'text', 'select').",
                              "example": "text",
                              "type": "string"
                            },
                            "value": {
                              "description": "Value stored in the custom field.",
                              "example": "SEECS",
                              "type": "string"
                            },
                            "name": {
                              "description": "Display label of the custom field.",
                              "example": "Institute",
                              "type": "string"
                            },
                            "shortname": {
                              "description": "Machine-readable shortname identifier for the custom field.",
                              "example": "institution",
                              "type": "string"
                            }
                          },
                          "required": [
                            "type",
                            "value",
                            "name",
                            "shortname"
                          ]
                        }
                      },
                      "preferences": {
                        "description": "List of stored preference key/value pairs for the user.",
                        "type": "array",
                        "items": {
                          "id": "UserPreference",
                          "title": "UserPreference",
                          "description": "A single user preference setting.",
                          "type": "object",
                          "properties": {
                            "name": {
                              "description": "Unique key identifying the preference.",
                              "example": "block_myoverview_user_sort_preference",
                              "type": "string"
                            },
                            "value": {
                              "description": "Preference value as a string. Note that the internal _lastloaded preference is returned as an integer by the LMS.",
                              "example": "title",
                              "type": "string"
                            }
                          },
                          "required": [
                            "name",
                            "value"
                          ]
                        }
                      }
                    },
                    "required": [
                      "id",
                      "username",
                      "fullname",
                      "email",
                      "department",
                      "institution",
                      "idnumber",
                      "auth",
                      "confirmed",
                      "lang",
                      "theme",
                      "timezone",
                      "mailformat",
                      "profileimageurlsmall",
                      "profileimageurl"
                    ]
                  }
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /core_user_get_user_preferences:
    post:
      description: >
        Returns all stored preference key/value pairs for the specified user. Optionally filter to a single preference by name.

        Moodle method: `core_user_get_user_preferences`
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      body:
        application/json:
          schema: |
            {
              "id": "GetUserPreferencesRequest",
              "title": "GetUserPreferencesRequest",
              "description": "Parameters specifying which user's preferences to retrieve.",
              "type": "object",
              "properties": {
                "userid": {
                  "description": "ID of the user whose preferences to retrieve.",
                  "example": 162154,
                  "type": "integer",
                  "format": "int32"
                },
                "name": {
                  "description": "Specific preference name to retrieve. Omit to retrieve all preferences.",
                  "type": "string"
                }
              },
              "required": [
                "userid"
              ]
            }
          example: ''
      responses:
        '200':
          description: User preferences list and optional warnings.
          body:
            application/json:
              schema: |
                {
                  "id": "UserPreferencesResponse",
                  "title": "UserPreferencesResponse",
                  "description": "Response envelope for the user-preferences endpoint.",
                  "type": "object",
                  "properties": {
                    "preferences": {
                      "description": "List of user preference key/value pairs.",
                      "type": "array",
                      "items": {
                        "id": "UserPreference",
                        "title": "UserPreference",
                        "description": "A single user preference setting.",
                        "type": "object",
                        "properties": {
                          "name": {
                            "description": "Unique key identifying the preference.",
                            "example": "block_myoverview_user_sort_preference",
                            "type": "string"
                          },
                          "value": {
                            "description": "Preference value as a string. Note that the internal _lastloaded preference is returned as an integer by the LMS.",
                            "example": "title",
                            "type": "string"
                          }
                        },
                        "required": [
                          "name",
                          "value"
                        ]
                      }
                    },
                    "warnings": {
                      "description": "Array of warning objects. Empty when no warnings are present.",
                      "type": "array",
                      "items": {
                        "id": "MoodleWarning",
                        "title": "MoodleWarning",
                        "description": "A non-fatal warning returned alongside a successful response.",
                        "type": "object",
                        "properties": {
                          "item": {
                            "description": "Item identifier related to the warning; empty string if not applicable.",
                            "type": "string"
                          },
                          "itemid": {
                            "description": "Numeric item ID related to the warning; 0 if not applicable.",
                            "example": 0,
                            "type": "integer",
                            "format": "int32"
                          },
                          "warningcode": {
                            "description": "Machine-readable warning code; empty string if no code.",
                            "type": "string"
                          },
                          "message": {
                            "description": "Human-readable warning description.",
                            "type": "string"
                          }
                        }
                      }
                    }
                  },
                  "required": [
                    "preferences",
                    "warnings"
                  ]
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /core_fetch_notifications:
    post:
      description: >
        Returns pending site-level notifications for the given Moodle context. Returns an empty array when there are no pending notifications.

        Moodle method: `core_fetch_notifications`
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      body:
        application/json:
          schema: |
            {
              "id": "FetchNotificationsRequest",
              "title": "FetchNotificationsRequest",
              "description": "Parameters specifying the context to fetch notifications for.",
              "type": "object",
              "properties": {
                "contextid": {
                  "description": "Moodle context ID for which to fetch notifications. The user context ID can be found in the user profile image URL path segment.",
                  "example": 1583361,
                  "type": "integer",
                  "format": "int32"
                }
              },
              "required": [
                "contextid"
              ]
            }
          example: ''
      responses:
        '200':
          description: Array of site notifications (empty array when none are pending).
          body:
            application/json:
              schema: |
                {
                  "description": "Site-level notifications for the given context; empty array when none are pending.",
                  "type": "array",
                  "items": {
                    "id": "SiteNotification",
                    "title": "SiteNotification",
                    "description": "A site-level notification (structure varies by type).",
                    "type": "object",
                    "properties": {
                      "id": {
                        "description": "Unique identifier for the site notification.",
                        "type": "integer",
                        "format": "int32"
                      },
                      "message": {
                        "description": "Notification message content.",
                        "type": "string"
                      },
                      "type": {
                        "description": "Notification type identifier.",
                        "type": "string"
                      }
                    }
                  }
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }
  /message_popup_get_popup_notifications:
    post:
      description: >
        Returns the most recent popup notifications sent to a user, with support for pagination. Also returns the total count of unread notifications.

        Moodle method: `message_popup_get_popup_notifications`
      headers:
        Content-Type:
          required: true
          displayName: Content-Type
          enum:
          - application/json
      body:
        application/json:
          schema: |
            {
              "id": "GetPopupNotificationsRequest",
              "title": "GetPopupNotificationsRequest",
              "description": "Parameters for the popup notifications request.",
              "type": "object",
              "properties": {
                "useridto": {
                  "description": "ID of the recipient user, passed as a string.",
                  "example": "162154",
                  "type": "string"
                },
                "limit": {
                  "description": "Maximum number of notifications to return.",
                  "example": 20,
                  "type": "integer",
                  "format": "int32"
                },
                "offset": {
                  "description": "Pagination offset.",
                  "example": 0,
                  "type": "integer",
                  "format": "int32"
                }
              },
              "required": [
                "useridto",
                "limit",
                "offset"
              ]
            }
          example: ''
      responses:
        '200':
          description: Popup notifications and total unread count.
          body:
            application/json:
              schema: |
                {
                  "id": "PopupNotificationsResponse",
                  "title": "PopupNotificationsResponse",
                  "description": "Response envelope for the popup-notifications endpoint.",
                  "type": "object",
                  "properties": {
                    "notifications": {
                      "description": "List of popup notifications for the user.",
                      "type": "array",
                      "items": {
                        "id": "Notification",
                        "title": "Notification",
                        "description": "A popup notification message delivered to a user.",
                        "type": "object",
                        "properties": {
                          "id": {
                            "description": "Unique notification identifier.",
                            "example": 4857819,
                            "type": "integer",
                            "format": "int32"
                          },
                          "useridfrom": {
                            "description": "User ID of the sender.",
                            "example": 198956,
                            "type": "integer",
                            "format": "int32"
                          },
                          "useridto": {
                            "description": "User ID of the recipient.",
                            "example": 162154,
                            "type": "integer",
                            "format": "int32"
                          },
                          "subject": {
                            "description": "Subject line of the notification.",
                            "example": "CS-419-Deep Learning: Lab Sessional Finalization",
                            "type": "string"
                          },
                          "shortenedsubject": {
                            "description": "Shortened version of the notification subject for compact display.",
                            "example": "CS-419-Deep Learning: Lab Sessional Finalization",
                            "type": "string"
                          },
                          "text": {
                            "description": "Short HTML excerpt of the notification.",
                            "example": "<p>Areeba Rameen posted in CS-419-Deep Learning...</p>",
                            "type": "string"
                          },
                          "fullmessage": {
                            "description": "Full plain-text body of the notification.",
                            "type": "string"
                          },
                          "fullmessageformat": {
                            "description": "Format identifier for fullmessagehtml (2 = Markdown source).",
                            "example": 2,
                            "type": "integer",
                            "format": "int32"
                          },
                          "fullmessagehtml": {
                            "description": "Full HTML body of the notification email.",
                            "type": "string"
                          },
                          "smallmessage": {
                            "description": "Short plain-text preview of the notification.",
                            "example": "Areeba Rameen posted in CS-419-Deep Learning...",
                            "type": "string"
                          },
                          "contexturl": {
                            "description": "URL to the relevant context for this notification (e.g., a forum post).",
                            "example": "https://lms.nust.edu.pk/portal/mod/forum/discuss.php?d=41767#p52342",
                            "type": "string"
                          },
                          "contexturlname": {
                            "description": "Human-readable label for the context URL link.",
                            "example": "Lab Sessional Finalization - (DL - Section D & E)",
                            "type": "string"
                          },
                          "timecreated": {
                            "description": "Unix timestamp when the notification was created.",
                            "example": 1780045085,
                            "type": "integer",
                            "format": "int32"
                          },
                          "timecreatedpretty": {
                            "description": "Human-readable relative time string (e.g., '19 days ago').",
                            "example": "19 days ago",
                            "type": "string"
                          },
                          "read": {
                            "description": "Whether the notification has been read by the recipient.",
                            "example": false,
                            "type": "boolean"
                          },
                          "deleted": {
                            "description": "Whether the notification has been deleted by the recipient.",
                            "example": false,
                            "type": "boolean"
                          },
                          "iconurl": {
                            "description": "URL to the icon image representing the notification source.",
                            "example": "https://lms.nust.edu.pk/portal/theme/image.php/moove/mod_forum/1778048051/icon",
                            "type": "string"
                          },
                          "component": {
                            "description": "Moodle component that generated the notification (e.g., 'mod_forum').",
                            "example": "mod_forum",
                            "type": "string"
                          },
                          "eventtype": {
                            "description": "Event type within the component that triggered the notification (e.g., 'posts').",
                            "example": "posts",
                            "type": "string"
                          },
                          "customdata": {
                            "description": "JSON-encoded string with additional notification metadata (cmid, instance, discussionid, postid, etc.).",
                            "example": {
                              "cmid": "1272420",
                              "instance": "62569",
                              "discussionid": "41767"
                            },
                            "type": "string"
                          },
                          "timeread": {
                            "description": "Unix timestamp when the notification was read; null if unread.",
                            "type": [
                              "integer",
                              "null"
                            ],
                            "format": "int32"
                          }
                        },
                        "required": [
                          "id",
                          "useridfrom",
                          "useridto",
                          "subject",
                          "shortenedsubject",
                          "text",
                          "fullmessage",
                          "fullmessageformat",
                          "fullmessagehtml",
                          "smallmessage",
                          "contexturl",
                          "contexturlname",
                          "timecreated",
                          "timecreatedpretty",
                          "read",
                          "deleted",
                          "iconurl",
                          "component",
                          "eventtype",
                          "customdata"
                        ]
                      }
                    },
                    "unreadcount": {
                      "description": "Total number of unread notifications for the user.",
                      "example": 1,
                      "type": "integer",
                      "format": "int32"
                    }
                  },
                  "required": [
                    "notifications",
                    "unreadcount"
                  ]
                }
        '400':
          description: Bad request or Moodle exception.
          body:
            application/json:
              schema: |
                {
                  "id": "MoodleError",
                  "title": "MoodleError",
                  "description": "Error returned by the LMS on a failed operation.",
                  "type": "object",
                  "properties": {
                    "errorcode": {
                      "description": "Machine-readable error code identifier.",
                      "example": "invalidrecord",
                      "type": "string"
                    },
                    "message": {
                      "description": "Human-readable error description.",
                      "example": "Can't find data record in database table.",
                      "type": "string"
                    },
                    "link": {
                      "description": "Redirect URL for the user; empty string if not applicable.",
                      "type": "string"
                    },
                    "moreinfourl": {
                      "description": "URL to additional error documentation; empty string if not available.",
                      "type": "string"
                    },
                    "debuginfo": {
                      "description": "Additional debug information; empty string when not in debug mode.",
                      "type": "string"
                    }
                  }
                }

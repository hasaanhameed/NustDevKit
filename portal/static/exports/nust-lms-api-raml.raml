- GetEnrolledCoursesByTimelineRequest: |
    {
      "$schema": "http://json-schema.org/draft-04/schema#",
      "id": "GetEnrolledCoursesByTimelineRequest",
      "title": "GetEnrolledCoursesByTimelineRequest",
      "description": "Request parameters for retrieving enrolled courses filtered by timeline classification.",
      "type": "object",
      "properties": {
        "offset": {
          "description": "Zero-based pagination offset.",
          "example": 0,
          "type": "integer",
          "format": "int32"
        },
        "limit": {
          "description": "Maximum number of courses to return.",
          "example": 50,
          "type": "integer",
          "format": "int32"
        },
        "classification": {
          "title": "CourseTimelineClassification",
          "description": "Timeline classification filter for enrolled courses.",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "all",
            "inprogress",
            "past",
            "future",
            "favourites",
            "hidden",
            "allincludinghidden"
          ]
        },
        "sort": {
          "title": "CourseTimelineSortField",
          "description": "Field used to sort enrolled course results.",
          "type": "string",
          "additionalProperties": false,
          "enum": [
            "fullname",
            "shortname",
            "id",
            "idnumber",
            "timeaccess"
          ]
        }
      },
      "required": [
        "offset",
        "limit",
        "classification",
        "sort"
      ]
    }

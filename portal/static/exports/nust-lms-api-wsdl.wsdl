<?xml version="1.0" encoding="utf-8"?>
<definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:schemas="http://127.0.0.1:8000/schemas" xmlns:wsdl="http://127.0.0.1:8000/wsdl" targetNamespace="http://127.0.0.1:8000/wsdl" xmlns="http://schemas.xmlsoap.org/wsdl/">
  <types>
    <xs:schema xmlns:tns="http://127.0.0.1:8000/schemas" targetNamespace="http://127.0.0.1:8000/schemas" xmlns:xs="http://www.w3.org/2001/XMLSchema">
      <xs:element name="POST_login_InputMessage" type="schemas:POST_login_InputMessage" />
      <xs:element name="POST_login_OutputMessage" type="schemas:POST_login_OutputMessage" />
      <xs:element name="POST_login_401" type="schemas:POST_login_401" />
      <xs:element name="POST_getCoreRecentCourses_InputMessage" type="schemas:POST_getCoreRecentCourses_InputMessage" />
      <xs:element name="POST_getCoreRecentCourses_OutputMessage" type="schemas:POST_getCoreRecentCourses_OutputMessage" />
      <xs:element name="POST_getCoreRecentCourses_400" type="schemas:POST_getCoreRecentCourses_400" />
      <xs:element name="POST_getEnrolledCoursesByTimeline_InputMessage" type="schemas:POST_getEnrolledCoursesByTimeline_InputMessage" />
      <xs:element name="POST_getEnrolledCoursesByTimeline_OutputMessage" type="schemas:POST_getEnrolledCoursesByTimeline_OutputMessage" />
      <xs:element name="POST_getEnrolledCoursesByTimeline_400" type="schemas:POST_getEnrolledCoursesByTimeline_400" />
      <xs:element name="POST_getCalendarEventsByTimesort_InputMessage" type="schemas:POST_getCalendarEventsByTimesort_InputMessage" />
      <xs:element name="POST_getCalendarEventsByTimesort_OutputMessage" type="schemas:POST_getCalendarEventsByTimesort_OutputMessage" />
      <xs:element name="POST_getCalendarEventsByTimesort_400" type="schemas:POST_getCalendarEventsByTimesort_400" />
      <xs:element name="POST_getCalendarEventsByCourse_InputMessage" type="schemas:POST_getCalendarEventsByCourse_InputMessage" />
      <xs:element name="POST_getCalendarEventsByCourse_OutputMessage" type="schemas:POST_getCalendarEventsByCourse_OutputMessage" />
      <xs:element name="POST_getCalendarEventsByCourse_400" type="schemas:POST_getCalendarEventsByCourse_400" />
      <xs:element name="POST_getUsersByField_InputMessage" type="schemas:POST_getUsersByField_InputMessage" />
      <xs:element name="POST_getUsersByField_OutputMessage" type="schemas:POST_getUsersByField_OutputMessage" />
      <xs:element name="POST_getUsersByField_400" type="schemas:POST_getUsersByField_400" />
      <xs:element name="POST_getUserPreferences_InputMessage" type="schemas:POST_getUserPreferences_InputMessage" />
      <xs:element name="POST_getUserPreferences_OutputMessage" type="schemas:POST_getUserPreferences_OutputMessage" />
      <xs:element name="POST_getUserPreferences_400" type="schemas:POST_getUserPreferences_400" />
      <xs:element name="POST_fetchNotifications_InputMessage" type="schemas:POST_fetchNotifications_InputMessage" />
      <xs:element name="POST_fetchNotifications_OutputMessage" type="schemas:POST_fetchNotifications_OutputMessage" />
      <xs:element name="POST_fetchNotifications_400" type="schemas:POST_fetchNotifications_400" />
      <xs:element name="POST_getPopupNotifications_InputMessage" type="schemas:POST_getPopupNotifications_InputMessage" />
      <xs:element name="POST_getPopupNotifications_OutputMessage" type="schemas:POST_getPopupNotifications_OutputMessage" />
      <xs:element name="POST_getPopupNotifications_400" type="schemas:POST_getPopupNotifications_400" />
      <xs:complexType name="LoginRequest">
        <xs:annotation>
          <xs:documentation>NUST LMS credentials used to obtain a gateway bearer token.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="username" type="xs:string">
            <xs:annotation>
              <xs:documentation>NUST LMS username.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="password" type="xs:string">
            <xs:annotation>
              <xs:documentation>NUST LMS password.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="TokenResponse">
        <xs:annotation>
          <xs:documentation>Bearer token issued by the gateway after a successful login.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="access_token" type="xs:string">
            <xs:annotation>
              <xs:documentation>JWT to send as `Authorization: Bearer &lt;token&gt;` on subsequent requests.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" default="bearer" name="token_type" type="xs:string" />
        </xs:sequence>
      </xs:complexType>
      <xs:simpleType name="CourseTimelineClassification">
        <xs:annotation>
          <xs:documentation>Timeline classification filter for enrolled courses.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
          <xs:enumeration value="all" />
          <xs:enumeration value="inprogress" />
          <xs:enumeration value="past" />
          <xs:enumeration value="future" />
          <xs:enumeration value="favourite" />
          <xs:enumeration value="hidden" />
          <xs:enumeration value="allincludinghidden" />
        </xs:restriction>
      </xs:simpleType>
      <xs:simpleType name="CourseTimelineSortField">
        <xs:annotation>
          <xs:documentation>Field used to sort enrolled course results.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
          <xs:enumeration value="fullname" />
          <xs:enumeration value="shortname" />
          <xs:enumeration value="id" />
          <xs:enumeration value="idnumber" />
          <xs:enumeration value="timeaccess" />
        </xs:restriction>
      </xs:simpleType>
      <xs:simpleType name="UserProfileField">
        <xs:annotation>
          <xs:documentation>User profile field to match against when searching for users.</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
          <xs:enumeration value="id" />
          <xs:enumeration value="idnumber" />
          <xs:enumeration value="username" />
          <xs:enumeration value="email" />
        </xs:restriction>
      </xs:simpleType>
      <xs:complexType name="MoodleWarning">
        <xs:annotation>
          <xs:documentation>A non-fatal warning returned alongside a successful response.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="0" name="item" type="xs:string">
            <xs:annotation>
              <xs:documentation>Item identifier related to the warning; empty string if not applicable.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="itemid" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Numeric item ID related to the warning; 0 if not applicable.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="warningcode" type="xs:string">
            <xs:annotation>
              <xs:documentation>Machine-readable warning code; empty string if no code.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="message" type="xs:string">
            <xs:annotation>
              <xs:documentation>Human-readable warning description.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="SiteNotification">
        <xs:annotation>
          <xs:documentation>A site-level notification (structure varies by type).</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="0" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unique identifier for the site notification.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="message" type="xs:string">
            <xs:annotation>
              <xs:documentation>Notification message content.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="type" type="xs:string">
            <xs:annotation>
              <xs:documentation>Notification type identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="MoodleError">
        <xs:annotation>
          <xs:documentation>Error returned by the LMS on a failed operation.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="0" name="errorcode" type="xs:string">
            <xs:annotation>
              <xs:documentation>Machine-readable error code identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="message" type="xs:string">
            <xs:annotation>
              <xs:documentation>Human-readable error description.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="link" type="xs:string">
            <xs:annotation>
              <xs:documentation>Redirect URL for the user; empty string if not applicable.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="moreinfourl" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to additional error documentation; empty string if not available.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="debuginfo" type="xs:string">
            <xs:annotation>
              <xs:documentation>Additional debug information; empty string when not in debug mode.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="Course">
        <xs:annotation>
          <xs:documentation>An enrolled course.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unique course identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="fullname" type="xs:string">
            <xs:annotation>
              <xs:documentation>Full display name of the course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="shortname" type="xs:string">
            <xs:annotation>
              <xs:documentation>Short course code or abbreviated name.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="idnumber" type="xs:string">
            <xs:annotation>
              <xs:documentation>Institution-assigned course ID number; empty string if not set.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="summary" type="xs:string">
            <xs:annotation>
              <xs:documentation>HTML summary of the course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="summaryformat" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Format of the summary field (1 = HTML).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="startdate" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Course start date as Unix timestamp.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="enddate" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Course end date as Unix timestamp. 0 means no end date.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="visible" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the course is visible to enrolled students.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="fullnamedisplay" type="xs:string">
            <xs:annotation>
              <xs:documentation>Display name of the course (may differ from fullname for context).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="viewurl" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to the course page on the LMS portal.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="progress">
            <xs:simpleType>
              <xs:annotation>
                <xs:documentation>Student's completion progress as a percentage.</xs:documentation>
              </xs:annotation>
              <xs:restriction base="xs:integer">
                <xs:maxInclusive value="100" />
                <xs:minInclusive value="0" />
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element minOccurs="1" name="hasprogress" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether completion tracking is enabled for this course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="isfavourite" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the user has marked this course as a favourite.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="hidden" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the user has hidden this course from their dashboard.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="showshortname" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the short name is displayed alongside the full name.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="coursecategory" type="xs:string">
            <xs:annotation>
              <xs:documentation>Name of the category this course belongs to.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="RecentCourseFields">
        <xs:annotation>
          <xs:documentation>Additional fields specific to recently accessed courses.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="timeaccess" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unix timestamp of the user's most recent access to this course.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="RecentCourse">
        <xs:annotation>
          <xs:documentation>A recently accessed course, extending Course with the last-access timestamp.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unique course identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="fullname" type="xs:string">
            <xs:annotation>
              <xs:documentation>Full display name of the course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="shortname" type="xs:string">
            <xs:annotation>
              <xs:documentation>Short course code or abbreviated name.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="idnumber" type="xs:string">
            <xs:annotation>
              <xs:documentation>Institution-assigned course ID number; empty string if not set.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="summary" type="xs:string">
            <xs:annotation>
              <xs:documentation>HTML summary of the course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="summaryformat" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Format of the summary field (1 = HTML).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="startdate" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Course start date as Unix timestamp.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="enddate" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Course end date as Unix timestamp. 0 means no end date.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="visible" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the course is visible to enrolled students.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="fullnamedisplay" type="xs:string">
            <xs:annotation>
              <xs:documentation>Display name of the course (may differ from fullname for context).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="viewurl" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL to the course page on the LMS portal.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="progress">
            <xs:simpleType>
              <xs:annotation>
                <xs:documentation>Student's completion progress as a percentage.</xs:documentation>
              </xs:annotation>
              <xs:restriction base="xs:integer">
                <xs:maxInclusive value="100" />
                <xs:minInclusive value="0" />
              </xs:restriction>
            </xs:simpleType>
          </xs:element>
          <xs:element minOccurs="1" name="hasprogress" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether completion tracking is enabled for this course.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="isfavourite" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the user has marked this course as a favourite.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="hidden" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the user has hidden this course from their dashboard.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="showshortname" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the short name is displayed alongside the full name.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="coursecategory" type="xs:string">
            <xs:annotation>
              <xs:documentation>Name of the category this course belongs to.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="timeaccess" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unix timestamp of the user's most recent access to this course.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="EnrolledCoursesResponse">
        <xs:annotation>
          <xs:documentation>Paginated enrolled-courses response.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" maxOccurs="unbounded" name="courses" type="schemas:Course">
            <xs:annotation>
              <xs:documentation>List of enrolled courses for the current page.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="nextoffset" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Offset to pass on the next page request; -1 when no further pages exist.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="EventIcon">
        <xs:annotation>
          <xs:documentation>Icon metadata for a calendar event.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="key" type="xs:string">
            <xs:annotation>
              <xs:documentation>Icon key name used to locate the icon asset.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="component" type="xs:string">
            <xs:annotation>
              <xs:documentation>Moodle component that owns the icon (e.g., 'assign').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="alttext" type="xs:string">
            <xs:annotation>
              <xs:documentation>Accessible alt text for the icon image.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="EventSubscription">
        <xs:annotation>
          <xs:documentation>Subscription display settings for a calendar event.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="displayeventsource" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether to display the event source label on the calendar.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="EventAction">
        <xs:annotation>
          <xs:documentation>Primary action button metadata for a calendar event.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Display label for the primary action button.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="url" type="xs:string">
            <xs:annotation>
              <xs:documentation>URL the user should navigate to in order to perform the action.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="itemcount" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Number of items associated with this action.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="actionable" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether the action can currently be taken by the user.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="showitemcount" type="xs:boolean">
            <xs:annotation>
              <xs:documentation>Whether to display the item count alongside the action label.</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="CalendarEvent">
        <xs:annotation>
          <xs:documentation>A calendar action event. On NUST LMS these represent deadlines — the due date for an assignment, lab, quiz, or other submission tied to a course activity.</xs:documentation>
        </xs:annotation>
        <xs:sequence>
          <xs:element minOccurs="1" name="id" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Unique calendar event identifier.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="name" type="xs:string">
            <xs:annotation>
              <xs:documentation>Display name of the calendar event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="description" type="xs:string">
            <xs:annotation>
              <xs:documentation>HTML description body of the event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="descriptionformat" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Text format of the description (1 = HTML).</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="location" type="xs:string">
            <xs:annotation>
              <xs:documentation>Physical or virtual location of the event; empty string if not specified.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="categoryid" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Course category ID; null if not a category event.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="groupid" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Group ID if the event is group-specific; null otherwise.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="userid" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>User ID if the event is user-specific; null otherwise.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="repeatid" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>ID of the repeat group for recurring events; null if not recurring.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="0" name="eventcount" nillable="true" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Total number of events in the repeat group; null if not applicable.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="component" type="xs:string">
            <xs:annotation>
              <xs:documentation>Moodle component that created the event (e.g., 'mod_assign').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="modulename" type="xs:string">
            <xs:annotation>
              <xs:documentation>Short name of the Moodle activity module (e.g., 'assign').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="instance" type="xs:integer">
            <xs:annotation>
              <xs:documentation>The course module instance ID.</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="eventtype" type="xs:string">
            <xs:annotation>
              <xs:documentation>Type of the event (e.g., 'due', 'open', 'close').</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element minOccurs="1" name="timestart" type="xs:integer">
            <xs:annotation>
              <xs:documentation>Event start time as Unix timestamp.</xs:documentation>

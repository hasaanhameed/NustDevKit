# Copy to backend/.env and adjust. backend/.env is gitignored.

# Long random string used to sign gateway JWTs (REQUIRED for production).
JWT_SECRET=change-me-to-a-long-random-string

# Bearer token lifetime, in minutes (default 720 = 12h).
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Upstream NUST LMS base URL.
LMS_BASE_URL=https://lms.nust.edu.pk

# CORS origins (JSON array). Use your docs/SDK origins in production.
# CORS_ORIGINS=["http://localhost:5173"]
